---
import { sanityClient } from '../lib/sanity.ts';

interface Props {
  currentSlug: string;
  currentTags: string[];
}
const { currentSlug, currentTags = [] } = Astro.props;

const allPosts = await sanityClient.fetch(
  `*[_type == "blogPost" && slug.current != $slug] {
    "slug": slug.current,
    title,
    excerpt,
    "image": heroImage.asset->url,
    publishDate,
    tags
  }`,
  { slug: currentSlug.replace('/blog/', '') },
);

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  if (!d) return '';
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const scored = allPosts
  .map((p: any) => ({
    ...p,
    score: (p.tags || []).filter((t: string) => currentTags.includes(t)).length,
  }))
  .sort((a: any, b: any) => b.score - a.score || new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime());

const related = (scored.some((p: any) => p.score > 0)
  ? scored.filter((p: any) => p.score > 0)
  : scored
).slice(0, 3);
---

{related.length > 0 && (
  <section class="rp-section">
    <div class="rp-inner">
      <h2 class="rp-heading">Related Reads</h2>
      <div class="rp-grid">
        {related.map((post: any) => (
          <a href={`/blog/${post.slug}`} class="rp-card">
            <div class="rp-img-wrap">
              {post.image ? (
                <img src={`${post.image}?w=600&h=400&fit=crop&auto=format`} alt={post.title} class="rp-img" />
              ) : (
                <div class="rp-img rp-img-fallback">{post.title}</div>
              )}
            </div>
            <div class="rp-card-body">
              {post.tags && post.tags.length > 0 && (
                <div class="rp-tags">
                  {post.tags.slice(0, 2).map((t: string) => (
                    <span class="rp-tag">{t}</span>
                  ))}
                </div>
              )}
              <h3 class="rp-title">{post.title}</h3>
              {post.publishDate && <p class="rp-date">{formatDate(post.publishDate)}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style is:inline>
  .rp-section {
    background: #faf6ed; padding: 80px 4vw;
    border-top: 1px solid #eee7d3;
  }
  .rp-inner { width: 1200px; max-width: 100%; margin: 0 auto; }
  .rp-heading {
    font-family: "Black Han Sans", sans-serif; font-weight: 400; font-size: 52px;
    color: #0a0a0a; text-transform: uppercase; line-height: 1;
    letter-spacing: -0.005em; margin: 0 0 8px;
    text-align: center;
  }
  .rp-heading::after {
    content: ""; display: block; width: 48px; height: 3px;
    background: #c9b36b; margin: 16px auto 0; border-radius: 2px;
  }

  .rp-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
    margin-top: 48px;
  }
  .rp-card {
    background: #fff; border: 1px solid #eee7d3; border-radius: 4px;
    text-decoration: none; overflow: hidden;
    display: flex; flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .rp-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 18px 40px rgba(10,10,10,0.10);
    border-color: #c9b36b;
  }
  .rp-card:hover .rp-img { transform: scale(1.06); }

  .rp-img-wrap { height: 220px; overflow: hidden; background: #f1ecda; }
  .rp-img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.6s ease;
  }
  .rp-img-fallback {
    display: flex; align-items: center; justify-content: center; background: #f1ecda;
    color: #8a7a50; font-family: "Almarai", sans-serif; font-size: 14px;
    font-weight: 800; text-transform: uppercase; letter-spacing: 1px; padding: 20px;
  }
  .rp-card-body {
    padding: 24px 24px 28px;
    display: flex; flex-direction: column; gap: 12px;
    flex: 1;
  }
  .rp-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .rp-tag {
    font-family: "Almarai", sans-serif; font-size: 10px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.2px;
    background: transparent; color: #8a7a50;
    padding: 4px 10px; border: 1px solid #e2ddce; border-radius: 999px;
  }
  .rp-title {
    font-family: "Black Han Sans", sans-serif; font-size: 22px; font-weight: 400;
    color: #0a0a0a; line-height: 1.15; text-transform: uppercase;
    letter-spacing: -0.002em; margin: 0;
  }
  .rp-date {
    font-family: "Almarai", sans-serif; font-size: 12px; color: #8a7a50;
    text-transform: uppercase; letter-spacing: 1.2px; margin: 4px 0 0;
    font-weight: 800;
  }

  @media (max-width: 960px) {
    .rp-section { padding: 60px 20px; }
    .rp-heading { font-size: 40px; }
    .rp-grid { grid-template-columns: 1fr; gap: 20px; margin-top: 36px; }
    .rp-img-wrap { height: 200px; }
  }
</style>
