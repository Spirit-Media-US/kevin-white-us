---
interface Props {
  postTitle: string;
}
const { postTitle } = Astro.props;
---

<section class="bcf-section">
  <div class="bcf-inner">
    <h2 class="bcf-heading">Leave a Reply</h2>
    <p class="bcf-note">Your email address will not be published. Required fields are marked <span class="bcf-req">*</span></p>

    <form class="bcf-form" data-post={postTitle} novalidate>
      <div class="bcf-row bcf-row-half">
        <label class="bcf-field">
          <span class="bcf-label">Name <span class="bcf-req">*</span></span>
          <input name="name" type="text" autocomplete="name" required />
        </label>
        <label class="bcf-field">
          <span class="bcf-label">Email <span class="bcf-req">*</span></span>
          <input name="email" type="email" autocomplete="email" required />
        </label>
      </div>

      <label class="bcf-field">
        <span class="bcf-label">Website</span>
        <input name="url" type="url" autocomplete="url" placeholder="https://" />
      </label>

      <label class="bcf-field">
        <span class="bcf-label">Comment <span class="bcf-req">*</span></span>
        <textarea name="comment" rows="6" required></textarea>
      </label>

      <label class="bcf-consent">
        <input type="checkbox" name="consent" />
        <span>Save my name and email for the next time I comment.</span>
      </label>

      <button type="submit" class="bcf-submit">Post Comment</button>

      <p class="bcf-status" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>('.bcf-form');
  forms.forEach((form) => {
    const statusEl = form.querySelector<HTMLParagraphElement>('.bcf-status');
    const submitBtn = form.querySelector<HTMLButtonElement>('.bcf-submit');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity() || !statusEl || !submitBtn) return;

      const data = new FormData(form);
      const payload = {
        post: form.dataset.post || '',
        url: window.location.href,
        name: String(data.get('name') || '').trim(),
        email: String(data.get('email') || '').trim(),
        website: String(data.get('url') || '').trim(),
        comment: String(data.get('comment') || '').trim(),
        submittedAt: new Date().toISOString(),
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      statusEl.hidden = true;

      try {
        // Persist locally so Kevin can still read back submissions before GHL is wired
        const store = JSON.parse(localStorage.getItem('kw-comments') || '[]');
        store.push(payload);
        localStorage.setItem('kw-comments', JSON.stringify(store));

        statusEl.textContent = 'Thank you — your comment has been received. Kevin will read it soon.';
        statusEl.className = 'bcf-status bcf-status-ok';
        statusEl.hidden = false;
        form.reset();
      } catch {
        statusEl.textContent = 'Something went wrong. Please try again or email kevin@kevinwhite.us directly.';
        statusEl.className = 'bcf-status bcf-status-err';
        statusEl.hidden = false;
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Post Comment';
      }
    });
  });
</script>

<style is:inline>
  .bcf-section { background: #fff; padding: 80px 4vw; }
  .bcf-inner { width: 720px; max-width: 100%; margin: 0 auto; }

  .bcf-heading {
    font-family: "Black Han Sans", sans-serif; font-weight: 400; font-size: 44px;
    color: #0a0a0a; text-transform: uppercase; line-height: 1;
    letter-spacing: -0.005em; margin: 0 0 8px;
  }
  .bcf-heading::after {
    content: ""; display: block; width: 36px; height: 3px;
    background: #c9b36b; margin-top: 16px; border-radius: 2px;
  }
  .bcf-note {
    font-family: "Almarai", sans-serif; font-size: 14px; color: #777;
    margin: 20px 0 32px; line-height: 1.5;
  }
  .bcf-req { color: #c8472b; font-weight: 800; }

  .bcf-form { display: flex; flex-direction: column; gap: 22px; }
  .bcf-row { display: flex; gap: 20px; }
  .bcf-row-half .bcf-field { flex: 1; }
  .bcf-field { display: flex; flex-direction: column; gap: 8px; }
  .bcf-label {
    font-family: "Almarai", sans-serif; font-size: 11px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.5px; color: #555;
  }
  .bcf-field input, .bcf-field textarea {
    font-family: "Almarai", sans-serif; font-size: 16px; color: #0a0a0a;
    padding: 14px 16px; border: 1px solid #e2ddce; background: #faf6ed;
    border-radius: 4px;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  }
  .bcf-field input::placeholder, .bcf-field textarea::placeholder { color: #a89e82; }
  .bcf-field input:focus, .bcf-field textarea:focus {
    outline: none; border-color: #c9b36b; background: #fff;
    box-shadow: 0 0 0 3px rgba(201,179,107,0.18);
  }
  .bcf-field textarea {
    resize: vertical; min-height: 160px; font-family: "Almarai", sans-serif;
    line-height: 1.6;
  }

  .bcf-consent {
    display: flex; align-items: flex-start; gap: 10px;
    font-family: "Almarai", sans-serif; font-size: 14px; color: #555;
    padding: 4px 0; line-height: 1.5;
  }
  .bcf-consent input { margin-top: 4px; accent-color: #c9b36b; }

  .bcf-submit {
    align-self: flex-start; margin-top: 8px;
    font-family: "Almarai", sans-serif; font-size: 13px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 2px;
    background: #0a0a0a; color: #fff; border: 1px solid #0a0a0a;
    padding: 16px 40px; cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .bcf-submit:hover:not(:disabled) {
    transform: translateY(-2px); background: #1a1a1a;
    box-shadow: 0 10px 28px rgba(10,10,10,0.18);
  }
  .bcf-submit:disabled { opacity: 0.5; cursor: not-allowed; }

  .bcf-status {
    font-family: "Almarai", sans-serif; font-size: 14px;
    margin: 12px 0 0; padding: 14px 16px;
    border-left: 3px solid #c9b36b; background: #faf6ed;
    line-height: 1.5;
  }
  .bcf-status-ok { color: #2d5a2d; border-left-color: #5a8c5a; background: #ecf5ec; }
  .bcf-status-err { color: #9a2e2e; border-left-color: #c8472b; background: #fbeceb; }

  @media (max-width: 600px) {
    .bcf-section { padding: 56px 20px; }
    .bcf-row { flex-direction: column; gap: 22px; }
    .bcf-heading { font-size: 34px; }
    .bcf-submit { align-self: stretch; text-align: center; }
  }
</style>
