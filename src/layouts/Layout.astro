---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'Kevin White — Serial entrepreneur, author, speaker, and Spirit Media founder', ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
import { IMG } from '../lib/images.ts';

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Speaker', href: '/speaking' },
  { label: 'Books', href: '/books' },
  { label: 'Spirit Media', href: 'https://spiritmedia.us/', external: true },
  { label: 'Magazines', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const socialLinks = [
  { label: 'YouTube', href: 'https://www.youtube.com/@KevinWhiteTV', icon: 'youtube' },
  { label: 'Instagram', href: 'https://www.instagram.com/kevinwhiteus/', icon: 'instagram' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/kevinwhiteus/', icon: 'linkedin' },
  { label: 'Twitter', href: 'https://twitter.com/kevinwhiteus', icon: 'twitter' },
  { label: 'Facebook', href: 'https://www.facebook.com/kevinwhite.usa', icon: 'facebook' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body>
    <!-- Header -->
    <header class="bg-white border-b border-[var(--color-border)]">
      <div class="container-site hidden lg:grid items-center" style="grid-template-columns: 25% 50% 25%; padding-top: 3vw; padding-bottom: 3vw;">
        <!-- Logo -->
        <a href="/" class="shrink-0">
          <img src={`${IMG.logo}?w=400&auto=format`} alt="Kevin White" style="height: 40px; width: auto;" />
        </a>

        <!-- Desktop nav -->
        <nav class="flex items-center justify-center gap-5">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'text-[18px]',
                'font-[var(--font-body)]',
                currentPath.startsWith(link.href) && !link.external
                  ? 'text-[var(--color-gold)]'
                  : 'text-[var(--color-text)] hover:text-[var(--color-gold)]'
              ]}
              style="transition: color 0.2s;"
              {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Social icons -->
        <div class="flex items-center justify-end" style="gap: 7px;">
          {socialLinks.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
               style="color: #000; fill: #000; padding: 10px; font-size: 20px; border-radius: 50px; display: inline-flex; align-items: center; justify-content: center; transition: color 0.2s;">
              <svg class="w-[20px] h-[20px]" fill="currentColor" viewBox="0 0 24 24">
                {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
                {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
                {s.icon === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {s.icon === 'twitter' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                {s.icon === 'facebook' && <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>}
              </svg>
            </a>
          ))}
        </div>

      </div>

      <!-- Mobile header -->
      <div class="container-site flex lg:hidden items-center justify-between" style="padding-top: 3vw; padding-bottom: 3vw;">
        <a href="/" class="shrink-0">
          <img src={`${IMG.logo}?w=400&auto=format`} alt="Kevin White" style="height: 32px; width: auto;" />
        </a>
        <button id="mobile-menu-btn" class="p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)]">
        <div class="container-site py-4 flex flex-col gap-3">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm font-medium text-[var(--color-text)]"
               {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {link.label}
            </a>
          ))}
          <div class="flex items-center gap-4 pt-3 border-t border-[var(--color-border)]">
            {socialLinks.map(s => (
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="text-[var(--color-text-light)]">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
                  {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
                  {s.icon === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                  {s.icon === 'twitter' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                  {s.icon === 'facebook' && <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>}
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </header>

    <slot />

    <!-- Footer — cloned from brxe-qhotsd -->
    <footer class="kw-footer">
      <div class="kw-footer-inner">
        <!-- Nav links — brxe-kgcbge / brxe-poxzfo -->
        <nav class="kw-footer-nav">
          {navLinks.map(link => (
            <a href={link.href} class="kw-footer-link"
               {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {link.label}
            </a>
          ))}
        </nav>
        <!-- Social icons — brxe-izwxtm -->
        <div class="kw-footer-social">
          {socialLinks.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="kw-footer-icon">
              <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24">
                {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
                {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
                {s.icon === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {s.icon === 'twitter' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                {s.icon === 'facebook' && <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>}
              </svg>
            </a>
          ))}
        </div>
      </div>
      <div style="text-align: center; margin-top: 20px; font-size: 12px; color: #262626;">
        &copy; {new Date().getFullYear()} Kevin White. All rights reserved. &bull; Powered by <a href="https://spiritmediapublishing.com" style="color: #262626;">Spirit Media</a>
      </div>
    </footer>

    <style is:inline>
      /* Footer — brxe-qhotsd */
      .kw-footer {
        background-color: #88cff1;
        border-top: 2px solid #262626;
        padding: 4vw 2vw;
      }
      .kw-footer-inner {
        display: flex;
        flex-direction: row;
        align-items: center;
        width: 1200px;
        max-width: 100%;
        margin: 0 auto;
      }
      /* Nav — brxe-kgcbge / brxe-poxzfo */
      .kw-footer-nav {
        width: 70%;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0;
      }
      .kw-footer-link {
        font-family: "Almarai", sans-serif;
        font-size: 18px;
        font-weight: 400;
        color: #fff;
        text-decoration: none;
        margin-left: 15px;
        transition: opacity 0.2s;
      }
      .kw-footer-link:first-child { margin-left: 0; }
      .kw-footer-link:hover { opacity: 0.7; }
      /* Social — brxe-izwxtm */
      .kw-footer-social {
        width: 40%;
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
      }
      .kw-footer-icon {
        color: #fff;
        fill: #fff;
        padding: 10px;
        font-size: 20px;
        border-radius: 50px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.2s;
      }
      .kw-footer-icon:hover { opacity: 0.7; }
      /* Mobile */
      @media (max-width: 478px) {
        .kw-footer { padding: 10vw 20px; }
        .kw-footer-inner {
          flex-direction: column;
          gap: 10px;
          padding-top: 5px;
        }
        .kw-footer-nav {
          width: 100%;
          justify-content: center;
          flex-direction: column;
          align-items: center;
        }
        .kw-footer-link { margin-left: 0; font-size: 3vw; }
        .kw-footer-social {
          width: 100%;
          justify-content: center;
          margin-top: 3vw;
        }
      }
    </style>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if (btn && menu) btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    </script>
  </body>
</html>
