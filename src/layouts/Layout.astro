---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
import { IMG } from '../lib/images.ts';
const defaultOgImage = `${IMG.kevin}?w=1200&h=630&fit=crop&auto=format`;
const { title, description = 'Kevin White — Serial entrepreneur, author, speaker, and Spirit Media founder', ogImage = defaultOgImage } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'About', href: '/about' },
  { label: 'Speaker', href: '/speaking' },
  { label: 'Books', href: '/books' },
  { label: 'Spirit Media', href: 'https://spiritmediapublishing.com/', external: true },
  { label: 'Magazines', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const socialLinks = [
  { label: 'YouTube', href: 'https://www.youtube.com/@KevinWhiteTV', icon: 'youtube' },
  { label: 'Instagram', href: 'https://www.instagram.com/kevinwhiteus/', icon: 'instagram' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/kevinwhiteus/', icon: 'linkedin' },
  { label: 'Twitter', href: 'https://twitter.com/kevinwhiteus', icon: 'twitter' },
  { label: 'Facebook', href: 'https://www.facebook.com/kevinwhite.usa', icon: 'facebook' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://kevinwhite.us${currentPath}`} />
    <meta property="og:site_name" content="Kevin White" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={`https://kevinwhite.us${currentPath}`} />

    <!-- Preconnect to font/asset origin — saves ~100ms on first font byte on mobile -->
    <link rel="preconnect" href="https://assets.spiritmediapublishing.com" crossorigin />
    <!-- Self-hosted fonts from R2 — no render-blocking external CSS.
         Only 2 preloads: 3+ preloads on the same R2 origin create HTTP/2 stream
         contention and push LCP +1s on mobile Slow-4G (verified 2026-04-21). -->
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/lexend/lexend-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="https://assets.spiritmediapublishing.com/fonts/lexend/lexend-500.woff2" crossorigin />
    <style is:inline set:html={`
      @font-face{font-family:'Almarai';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/almarai/almarai-400.woff2') format('woff2');}
      @font-face{font-family:'Almarai';font-style:normal;font-weight:700;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/almarai/almarai-700.woff2') format('woff2');}
      @font-face{font-family:'Black Han Sans';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/black-han-sans/black-han-sans-400.woff2') format('woff2');}
      @font-face{font-family:'Crimson Text';font-style:italic;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/crimson-text/crimson-text-400-italic.woff2') format('woff2');}
      @font-face{font-family:'Crimson Text';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/crimson-text/crimson-text-400.woff2') format('woff2');}
      @font-face{font-family:'Crimson Text';font-style:normal;font-weight:600;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/crimson-text/crimson-text-600.woff2') format('woff2');}
      @font-face{font-family:'Crimson Text';font-style:normal;font-weight:700;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/crimson-text/crimson-text-700.woff2') format('woff2');}
      @font-face{font-family:'Lexend';font-style:normal;font-weight:400;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/lexend/lexend-400.woff2') format('woff2');}
      @font-face{font-family:'Lexend';font-style:normal;font-weight:500;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/lexend/lexend-500.woff2') format('woff2');}
      @font-face{font-family:'Lexend';font-style:normal;font-weight:600;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/lexend/lexend-600.woff2') format('woff2');}
      @font-face{font-family:'Lexend';font-style:normal;font-weight:700;font-display:optional;src:url('https://assets.spiritmediapublishing.com/fonts/lexend/lexend-700.woff2') format('woff2');}
    `} />

    <slot name="head" />

    <!-- Reveal + premium animations (global).
         CRITICAL: transitions are TRANSFORM-ONLY, no opacity. Lighthouse captures
         frames mid-transition; a 0.7s opacity fade catches text at ~50% opacity →
         40+ false color-contrast fails. Transform-only gives the same slide-in
         without the A11y artifact. Do NOT add opacity back.
         CSS below is wrapped in @layer base so Tailwind's @layer utilities
         (grid-cols-*, h-*, etc.) still wins the cascade when the async bundle
         arrives. @keyframes/@font-face stay outside the layer (spec forbids). -->
    <style is:inline>
      /* ============================================================
         CRITICAL CSS — covers every above-fold layout rule on the
         homepage so the external Tailwind chunk can load deferred at
         end of body without triggering CLS. Don't remove anything
         without re-running PSI mobile.
         ============================================================ */

      /* Theme tokens (mirrors @theme in global.css). */
      :root {
        --color-black: #000;
        --color-white: #fff;
        --color-gray: #595959;
        --color-light-gray: #d9d9d9;
        --color-blue: #89cff0;
        --color-blue-dark: #6bb8e0;
        --color-bg: #fff;
        --color-text: #000;
        --color-text-light: #595959;
        --color-text-gray: #595959;
        --color-gold: #b38b3a;
        --color-border: #e5e5e5;
        --font-heading: "Lexend", sans-serif;
        --font-body: "Almarai", sans-serif;
        --font-display: "Black Han Sans", sans-serif;
        --font-serif: "Crimson Text", serif;
        --container-max: 1440px;
      }

      /* Minimal preflight (replaces Tailwind preflight for above-fold). */
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      body { margin: 0; font-family: var(--font-body); color: var(--color-text); background: var(--color-bg); line-height: 1.6; font-size: 16px; overflow-x: hidden; }
      h1, h2, h3, h4, h5, h6 { margin: 0; font-family: var(--font-heading); font-weight: 600; line-height: 1.2; color: var(--color-black); }
      h1 { font-size: clamp(40px, 9vw, 80px); }
      h2 { font-size: clamp(24px, 4vw, 30px); }
      h3 { font-size: clamp(18px, 2.6vw, 20px); }
      p { margin: 0; }
      p, h1, h2, h3, h4, h5, h6, li, blockquote { overflow-wrap: break-word; word-wrap: break-word; }
      a { color: inherit; text-decoration: none; }
      button { background: none; border: 0; font: inherit; cursor: pointer; padding: 0; }
      img, video, iframe, svg, canvas { max-width: 100%; height: auto; display: block; }
      video { background: #000; }
      section, main { max-width: 100%; }
      ul, ol { margin: 0; padding: 0; }

      /* Site containers. */
      .container-site { width: var(--container-max); max-width: 100%; margin: 0 auto; padding-left: clamp(16px, 3vw, 32px); padding-right: clamp(16px, 3vw, 32px); box-sizing: border-box; }
      .text-gray { color: var(--color-gray); }

      /* Header (custom classes, not Tailwind). */
      .kw-desktop-only { display: none; }
      .kw-mobile-only { display: flex; }
      @media (min-width: 1024px) {
        .kw-desktop-only { display: grid; }
        .kw-mobile-only { display: none; }
      }

      /* Tailwind utility subset — every class used on the homepage that
         affects LAYOUT (not purely cosmetic). Inline so the page stays
         stable before external CSS arrives. */
      .block { display: block; }
      .flex { display: flex; }
      .grid { display: grid; }
      .hidden { display: none; }
      .inline-flex { display: inline-flex; }
      .inline-block { display: inline-block; }
      .relative { position: relative; }
      .absolute { position: absolute; }
      .flex-col { flex-direction: column; }
      .flex-row { flex-direction: row; }
      .flex-wrap { flex-wrap: wrap; }
      .items-center { align-items: center; }
      .items-start { align-items: flex-start; }
      .items-end { align-items: flex-end; }
      .justify-center { justify-content: center; }
      .justify-between { justify-content: space-between; }
      .justify-end { justify-content: flex-end; }
      .justify-start { justify-content: flex-start; }
      .shrink-0 { flex-shrink: 0; }
      .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
      .gap-1 { gap: 0.25rem; }
      .gap-2 { gap: 0.5rem; }
      .gap-3 { gap: 0.75rem; }
      .gap-4 { gap: 1rem; }
      .gap-5 { gap: 1.25rem; }
      .gap-6 { gap: 1.5rem; }
      .gap-8 { gap: 2rem; }
      .mx-auto { margin-left: auto; margin-right: auto; }
      .mt-2 { margin-top: 0.5rem; }
      .mt-3 { margin-top: 0.75rem; }
      .mt-4 { margin-top: 1rem; }
      .mt-6 { margin-top: 1.5rem; }
      .mb-2 { margin-bottom: 0.5rem; }
      .mb-3 { margin-bottom: 0.75rem; }
      .mb-4 { margin-bottom: 1rem; }
      .p-2 { padding: 0.5rem; }
      .p-4 { padding: 1rem; }
      .pt-3 { padding-top: 0.75rem; }
      .py-4 { padding-top: 1rem; padding-bottom: 1rem; }
      .py-8 { padding-top: 2rem; padding-bottom: 2rem; }
      .py-12 { padding-top: 3rem; padding-bottom: 3rem; }
      .py-16 { padding-top: 4rem; padding-bottom: 4rem; }
      .max-w-xl { max-width: 36rem; }
      .max-w-4xl { max-width: 56rem; }
      .max-w-7xl { max-width: 80rem; }
      .w-4 { width: 1rem; }
      .w-6 { width: 1.5rem; }
      .h-4 { height: 1rem; }
      .h-6 { height: 1.5rem; }
      .overflow-hidden { overflow: hidden; }
      .rounded-lg { border-radius: 0.5rem; }
      .rounded-full { border-radius: 9999px; }
      .border { border-width: 1px; border-style: solid; }
      .border-b { border-bottom-width: 1px; border-bottom-style: solid; }
      .border-t { border-top-width: 1px; border-top-style: solid; }
      .text-center { text-align: center; }
      .text-white { color: #fff; }
      .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
      .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
      .font-medium { font-weight: 500; }
      .font-bold { font-weight: 700; }
      .uppercase { text-transform: uppercase; }
      .bg-white { background-color: #fff; }
      .bg-cover { background-size: cover; }
      .bg-center { background-position: center; }
      .z-10 { z-index: 10; }

      /* Arbitrary values used on this site. */
      .text-\[18px\] { font-size: 18px; }
      .font-\[var\(--font-body\)\] { font-family: var(--font-body); }
      .text-\[var\(--color-text\)\] { color: var(--color-text); }
      .text-\[var\(--color-text-light\)\] { color: var(--color-text-light); }
      .text-\[var\(--color-gold\)\] { color: var(--color-gold); }
      .border-\[var\(--color-border\)\] { border-color: var(--color-border); }

      /* Responsive utilities used. */
      @media (min-width: 768px) {
        .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .md\:py-12 { padding-top: 3rem; padding-bottom: 3rem; }
        .md\:py-16 { padding-top: 4rem; padding-bottom: 4rem; }
        .md\:text-lg { font-size: 1.125rem; line-height: 1.75rem; }
      }
      @media (min-width: 1024px) {
        .lg\:hidden { display: none; }
        .lg\:grid { display: grid; }
        .lg\:flex { display: flex; }
        .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        .lg\:grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
        .lg\:py-16 { padding-top: 4rem; padding-bottom: 4rem; }
        .lg\:py-20 { padding-top: 5rem; padding-bottom: 5rem; }
        .lg\:px-8 { padding-left: 2rem; padding-right: 2rem; }
      }

      @layer base {
        /* Reveal-on-scroll REMOVED — the rAF+getBoundingClientRect loop was
           triggering a 200ms forced reflow on Lighthouse mobile, bumping
           LCP +1.7s. Sections now render in place, no transform on mount. */

        /* Subtle card/link lift on hover (no forced reflow). */
        .ba-book-block a, .mag-card, .sp-pod-item, .bk-book-row { transition: transform 0.3s ease, box-shadow 0.3s ease; }
        .ba-book-block a:hover, .sp-pod-item:hover { transform: translateY(-4px); }

        html { scroll-behavior: smooth; }
        a, button { transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease; }
      }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header class="bg-white border-b border-[var(--color-border)]">
      <div class="container-site kw-desktop-only items-center" style="grid-template-columns: 25% 50% 25%; padding-top: 3vw; padding-bottom: 3vw;">
        <!-- Logo -->
        <a href="/" class="shrink-0">
          <img src={`${IMG.logo}?w=726&h=75&auto=format`} alt="Kevin White" width="726" height="75" style="height: 30px; width: auto;" />
        </a>

        <!-- Desktop nav -->
        <nav class="flex items-center justify-center gap-5">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'text-[18px]',
                'font-[var(--font-body)]',
                currentPath.startsWith(link.href) && !link.external
                  ? 'text-[var(--color-gold)]'
                  : 'text-[var(--color-text)] hover:text-[var(--color-gold)]'
              ]}
              style="transition: color 0.2s; padding: 8px 4px; display: inline-block;"
              {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Social icons -->
        <div class="flex items-center justify-end" style="gap: 7px;">
          {socialLinks.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
               style="color: #000; fill: #000; padding: 10px; font-size: 20px; border-radius: 50px; display: inline-flex; align-items: center; justify-content: center; transition: color 0.2s;">
              <svg class="w-[20px] h-[20px]" fill="currentColor" viewBox="0 0 24 24">
                {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
                {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
                {s.icon === 'linkedin' && <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>}
                {s.icon === 'twitter' && <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>}
                {s.icon === 'facebook' && <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.313 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>}
              </svg>
            </a>
          ))}
        </div>

      </div>

      <!-- Mobile header -->
      <div class="container-site kw-mobile-only items-center justify-between" style="padding-top: 3vw; padding-bottom: 3vw;">
        <a href="/" class="shrink-0">
          <img src={`${IMG.logo}?w=726&h=75&auto=format`} alt="Kevin White" width="726" height="75" style="height: 32px; width: auto;" />
        </a>
        <button id="mobile-menu-btn" class="p-2" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)]">
        <div class="container-site py-4 flex flex-col gap-3">
          {navLinks.map(link => (
            <a href={link.href} class="text-sm font-medium text-[var(--color-text)]"
               {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {link.label}
            </a>
          ))}
          <div class="flex items-center gap-4 pt-3 border-t border-[var(--color-border)]">
            {socialLinks.map(s => (
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="text-[var(--color-text-light)]">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  {s.icon === 'youtube' && <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>}
                  {s.icon === 'instagram' && <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>}
