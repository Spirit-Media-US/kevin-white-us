---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';
import { IMG, VIDEO } from '../lib/images.ts';

const books = await sanityClient.fetch(`*[_type == "book"] | order(order asc) { title, amazonUrl, "coverImage": coverImage.asset->url }`);
const posts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishDate desc) [0...3] { "slug": slug.current, title, "image": heroImage.asset->url }`);
---

<Layout title="Kevin White — Author, Speaker, Entrepreneur" description="Kevin White is a serial entrepreneur, bestselling author, and conference speaker who equips leaders to live out God's Word and prioritize prayer.">
  <Fragment slot="head">
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "Person", "name": "Kevin White",
      "url": "https://kevinwhite.us", "jobTitle": "Founder & Chief Spiritual Officer",
      "worksFor": { "@type": "Organization", "name": "Spirit Media" },
      "sameAs": ["https://www.youtube.com/@KevinWhiteTV","https://www.instagram.com/kevinwhiteus/","https://www.linkedin.com/in/kevinwhiteus/","https://twitter.com/kevinwhiteus"]
    })}></script>
    <!-- Below-fold CSS extracted out of inline so HTML stays small.
         Postbuild (scripts/defer-css.mjs) moves this to end of body. -->
    <link rel="stylesheet" href="/homepage-below.css" />
  </Fragment>

  <main>
    <!-- Hero: photo via ::before pseudo-element (excluded from LCP
         candidacy per Chrome spec) + H1 text overlay. Mobile gets a
         640w variant (~45KB), desktop upscales to 1200w. The gradient
         stays as a fill behind the image for faster first paint. -->
    <section class="home-hero relative flex items-center text-white">
      <div class="container-site relative z-10 py-12 md:py-16">
        <h1 class="home-hero-h1">
          NOTHING<br />CHANGES<br />OUR LIVES<br />MORE THAN<br />PRIORITIZING PRAYER
        </h1>
      </div>
    </section>
    <style is:inline>
      /* NOT wrapped in @layer base: global.css has an unlayered
         `h1,h2,h3 { color: #000 }` rule that would otherwise win and
         turn this hero's H1 black. None of these rules touch display/grid
         utilities, so staying unlayered is safe here. */
      .home-hero {
        min-height: clamp(420px, 70vh, 760px);
        height: auto;
        overflow: hidden;
        background: linear-gradient(135deg, #0b1e33 0%, #143054 55%, #0b1e33 100%);
      }
      /* Hero photo via ::before — ::before backgrounds are excluded from
         Chrome's LCP candidate selection, so H1 text stays the LCP. */
      .home-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url('https://cdn.sanity.io/images/kwhqwbb4/production/5751308142cca7852196a388c3d232a2cb5f5784-1200x700.jpg?w=640&fm=webp&q=72&auto=format');
        background-size: cover;
        background-position: center;
        z-index: 0;
      }
      @media (min-width: 1024px) {
        .home-hero::before {
          background-image: url('https://cdn.sanity.io/images/kwhqwbb4/production/5751308142cca7852196a388c3d232a2cb5f5784-1200x700.jpg?w=1200&fm=webp&q=80&auto=format');
        }
      }
      .home-hero-h1 {
        /* System-font stack — no webfont fetch, LCP can fire at first paint.
           Lexend causes a 1.5s FCP→LCP gap from font swap/synthesis on
           mobile Slow-4G. This is the LCP element, so it wins the perf
           trade against the 1px of visual difference. */
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        font-size: clamp(32px, 9vw, 80px);
        color: #fff;
        line-height: 1.05;
        font-weight: 900;
        letter-spacing: -0.01em;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
      }
      @media (max-width: 768px) {
        .home-hero {
          min-height: 420px;
          justify-content: flex-end;
        }
        .home-hero .container-site { text-align: right; }
        .home-hero-h1 { text-align: right; }
      }
      /* YT/IG section background via ::before so it's excluded from LCP
         candidate selection. Mobile gets a 640w webp (~33KB); desktop
         upscales to 1600w. */
      .yt-ig-section > * { position: relative; z-index: 1; }
      .yt-ig-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: url('https://cdn.sanity.io/images/kwhqwbb4/production/d4e27107db3a661a83b73edce68d01dae465b9ef-2560x1440.jpg?w=640&fm=webp&q=72&auto=format');
        background-size: cover;
        background-position: center;
        z-index: 0;
      }
      @media (min-width: 1024px) {
        .yt-ig-section::before {
          background-image: url('https://cdn.sanity.io/images/kwhqwbb4/production/d4e27107db3a661a83b73edce68d01dae465b9ef-2560x1440.jpg?w=1600&fm=webp&q=75&auto=format');
        }
      }
    </style>

    <!-- Kevin White Quote. Reserve height with min-height so any text
         reflow (font load, class activation) doesn't propagate a layout
         shift down to the YT/IG section. -->
    <section class="bg-white" style="padding: 3vw 2vw; min-height: 280px; display: flex; align-items: center;">
      <div class="container-site text-center max-w-4xl mx-auto">
        <p style="font-family: Georgia, 'Times New Roman', serif; font-size: 20px; line-height: 1.6; color: var(--color-text);">
          "I have valued prayer my whole life, but when I prioritized prayer above everything else on my calendar I immediately witnessed God's miracles in my life, marriage, family, companies, and world. You can too! Allow me to empower you in prioritizing prayer."
        </p>
        <p style="font-family: var(--font-body); font-size: 16px; margin-top: 12px; color: var(--color-gray);">- Kevin White</p>
      </div>
    </section>

    <!-- YouTube + Instagram: 2 column. Background image loads on desktop
         only; mobile uses a solid dark color to save ~33KB bandwidth and
         not compete with critical-path resources. -->
    <section class="yt-ig-section relative" style="padding: 4vw 2vw; background: #1a2332;">
      <div class="container-site grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- YouTube -->
        <div class="text-center" style="padding: 3vw 2vw;">
          <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube — Kevin White's channel" class="flex items-center justify-center gap-3 mb-4" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: clamp(16px, 2.5vw, 25px); color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em;">
            <svg style="width: 40px; height: 40px; flex-shrink: 0;" fill="white" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span aria-hidden="true">&rarr;</span> Watch on YouTube
          </a>
          <p style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 16px; line-height: 150%; color: #fff; text-transform: uppercase; font-weight: 700;">
            Stay connected and receive encouragement every week on Kevin's YouTube channel
          </p>
        </div>
        <!-- Instagram -->
        <div class="text-center" style="padding: 3vw 2vw;">
          <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" aria-label="Follow on Instagram — Kevin White's page" class="flex items-center justify-center gap-3 mb-4" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: clamp(16px, 2.5vw, 25px); color: #fff; font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em;">
            <svg style="width: 40px; height: 40px; flex-shrink: 0;" fill="white" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <span aria-hidden="true">&rarr;</span> Follow on Instagram
          </a>
          <p style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 16px; line-height: 150%; color: #fff; text-transform: uppercase; font-weight: 700;">
            See the latest on Kevin's Instagram page
          </p>
        </div>
      </div>
    </section>

    <!-- Serial Entrepreneur — cloned from live site CSS -->
    <section class="se-section">
      <div style="width: 1200px; max-width: 100%; margin: 0 auto; text-align: center; padding: 4vw 4vw 3vw;">
        <h2 style="font-family: Impact, "Arial Black", sans-serif; font-size: clamp(36px, 7.5vw, 74px); color: #000; line-height: 50px; text-transform: uppercase; font-weight: 400;">Serial Entrepreneur</h2>
      </div>
      <div class="se-row">
        <!-- Text column -->
        <div class="se-text-col">
          <p class="se-paragraph">
            Kevin is known as "God's startup guy." God has used Kevin to bring hundreds of businesses, nonprofits, and churches to life globally. Kevin is a visionary leader who measures success through spiritual transformation. His work as the founder of <a href="https://spiritmediapublishing.com/" target="_blank" rel="noopener noreferrer">Spirit Media</a> and other companies within White Enterprise allows him to empower businesses worldwide to lead with impact.
          </p>
          <a href="https://spiritmediapublishing.com/" target="_blank" rel="noopener noreferrer" class="se-button" aria-label="Learn more about Spirit Media">Learn more about Spirit Media</a>
        </div>
        <!-- Video column -->
        <div class="se-video-col">
          <video autoplay loop playsinline muted preload="none" class="se-video lazy-video">
            <source data-src={VIDEO.entrepreneurLoop} type="video/mp4" />
          </video>
        </div>
      </div>
    </section>

    <!-- Conference Speaker heading — brxe-fnekom -->
    <div class="cs-heading-wrap">
      <h2 class="cs-heading">Conference Speaker</h2>
    </div>

    <!-- Conference Speaker section — brxe-czmhlo -->
    <section class="cs-section">
      <div class="cs-row">
        <!-- Video column (left) — brxe-zcafxp -->
        <div class="cs-video-col">
          <video autoplay loop playsinline muted preload="none" class="cs-video lazy-video">
            <source data-src={VIDEO.conferenceSpeakerLoop} type="video/mp4" />
          </video>
        </div>
        <!-- Text column (right) — brxe-yqknsm -->
        <div class="cs-text-col">
          <p class="cs-paragraph">
            Kevin actively equips and empowers leaders all over the world to live out God's Word in their everyday lives. He loves to guide people into God's presence, Word, kingdom, generosity, mission, and purpose. Kevin regularly empowers and equips all Believers in prioritizing prayer, the fear of God, and kingdom impact through business and nonprofit development. Schedule Kevin to bring value to your audience.
          </p>
          <a href="/speaking" class="cs-button" aria-label="Explore speaking topics">Explore speaking topics</a>
        </div>
      </div>
    </section>

    <!-- Bestselling Author — cloned from live site CSS -->
    <section class="ba-section">
      <div class="ba-container">
        <h2 class="ba-heading">Bestselling Author</h2>
        <p class="ba-description">
          Kevin has published seven books in five years. His eighth book will be released in 2025.&nbsp;Each book equips and empowers believers to live out God's Word in their everyday lives.
        </p>

        {/* Row 1: 4 books */}
        <div class="ba-row">
          {books.slice(0, 4).map((book: any) => (
            <div class="ba-book-block">
              <a href={book.amazonUrl || '/books'} target="_blank" rel="noopener noreferrer">
                <figure class="ba-book-figure">
                  {book.coverImage ? (
                    <img
                      src={`${book.coverImage}?w=220&fm=webp&q=75&auto=format`}
                      srcset={`${book.coverImage}?w=220&fm=webp&q=75&auto=format 220w, ${book.coverImage}?w=400&fm=webp&q=80&auto=format 400w`}
                      sizes="(max-width: 478px) 22vw, 200px"
                      width="220"
                      height="352"
                      alt={book.title}
                      class="ba-book-img"
                      loading="lazy" fetchpriority="low"
                      decoding="async"
                    />
                  ) : (
                    <div class="img-placeholder" style="width: 100%; height: 100%;">{book.title}</div>
                  )}
                </figure>
              </a>
            </div>
          ))}
        </div>

        {/* Row 2: remaining books + Kings of the King */}
        <div class="ba-row">
          {books.slice(4).map((book: any) => (
            <div class="ba-book-block">
              <a href={book.amazonUrl || '/books'} target="_blank" rel="noopener noreferrer">
                <figure class="ba-book-figure">
                  {book.coverImage ? (
                    <img
                      src={`${book.coverImage}?w=220&fm=webp&q=75&auto=format`}
                      srcset={`${book.coverImage}?w=220&fm=webp&q=75&auto=format 220w, ${book.coverImage}?w=400&fm=webp&q=80&auto=format 400w`}
                      sizes="(max-width: 478px) 22vw, 200px"
                      width="220"
                      height="352"
                      alt={book.title}
                      class="ba-book-img"
                      loading="lazy" fetchpriority="low"
                      decoding="async"
                    />
                  ) : (
                    <div class="img-placeholder" style="width: 100%; height: 100%;">{book.title}</div>
                  )}
                </figure>
              </a>
            </div>
          ))}
          {/* 8th book: Kings of the King */}
          <div class="ba-book-block">
            <a href="/books">
              <figure class="ba-book-figure">
                <img
                  src={`${IMG.kingsBook}?w=220&fm=webp&q=75&auto=format`}
                  srcset={`${IMG.kingsBook}?w=220&fm=webp&q=75&auto=format 220w, ${IMG.kingsBook}?w=400&fm=webp&q=80&auto=format 400w`}
                  sizes="(max-width: 478px) 22vw, 200px"
                  width="220"
                  height="352"
                  alt="Kings of the King"
                  class="ba-book-img"
                  loading="lazy" fetchpriority="low"
                  decoding="async"
                />
              </figure>
            </a>
          </div>
        </div>

        <p class="ba-download">Download my international bestseller</p>

        {/* Overlapping book composition — brxe-pnfzog / brxe-fxwymo / brxe-oglwmg */}
        <div class="ba-book-comp">
          <img
            src={`${IMG.getToPointSample}?w=280&fm=webp&q=75&auto=format`}
            srcset={`${IMG.getToPointSample}?w=280&fm=webp&q=75&auto=format 280w, ${IMG.getToPointSample}?w=400&fm=webp&q=80&auto=format 400w`}
            sizes="(max-width: 478px) 140px, 200px"
            width="200"
            height="320"
            alt="Get to the Point sample page"
            class="ba-book-back"
            loading="lazy" fetchpriority="low"
            decoding="async"
          />
          <img
            src={books[1]?.coverImage ? `${books[1].coverImage}?w=280&fm=webp&q=75&auto=format` : `${IMG.getToPointSample}?w=280&fm=webp&q=75&auto=format`}
            srcset={books[1]?.coverImage
              ? `${books[1].coverImage}?w=280&fm=webp&q=75&auto=format 280w, ${books[1].coverImage}?w=400&fm=webp&q=80&auto=format 400w`
              : `${IMG.getToPointSample}?w=280&fm=webp&q=75&auto=format 280w, ${IMG.getToPointSample}?w=400&fm=webp&q=80&auto=format 400w`}
            sizes="(max-width: 478px) 140px, 200px"
            width="200"
            height="320"
            alt="Get to the Point"
            class="ba-book-front"
            loading="lazy" fetchpriority="low"
            decoding="async"
          />
        </div>


      </div>
    </section>

    <!-- NPO Coaching Banner — brxe-mrxnju -->
    <section class="npo-section">
      <div class="npo-container">
        <a href="https://drive.google.com/file/d/1GVJGb50cSwhotRYbf1doRz8BHUVrYerf/view?usp=drive_link" target="_blank" rel="noopener noreferrer" class="npo-image-link">
          <img src={`${IMG.npoBanner}?w=1200&fm=webp&q=80&auto=format`} alt="NPO Coaching Banner" class="npo-image" loading="lazy" fetchpriority="low" decoding="async" />
        </a>
      </div>
    </section>

    <!-- Fundraiser — cloned from brxe-hhoquz -->
    <section class="fr-section">
      <div class="fr-outer">
        <div class="fr-content">
          {/* Two-column row — brxe-ornmgx flex-direction: row */}
          <div class="fr-columns">
            {/* Left sub-column — brxe-jirzaa */}
            <div class="fr-col-left">
              <h2 class="fr-heading">Fundraiser</h2>
              <p class="fr-text">
                As a young boy, Kevin was always one of the top fundraisers in the Royal Rangers. God's anointing for fundraising has been on Kevin his whole life. God has used Kevin to:
              </p>
              <ul class="fr-list">
                <li><span class="fr-arrow">&rarr;</span><span>Start hundreds of nonprofits and guide them to raise $100M+ in donations.</span></li>
                <li><span class="fr-arrow">&rarr;</span><span>Strengthen hundreds of startup companies worldwide.</span></li>
                <li><span class="fr-arrow">&rarr;</span><span>Empower hundreds of ministers and missionaries around the world to start income generation projects.</span></li>
              </ul>
            </div>
            {/* Right sub-column — brxe-fqgshn */}
            <div class="fr-col-right">
              <p class="fr-text">
                In doing so, Kevin knows the art of articulating and selling vision. The Bible teaches that money follows vision. Every money problem is a lack of vision. Unfortunately, most people struggle to articulate and sell the vision God has given them. Let Kevin help you:
              </p>
              <ul class="fr-list">
                <li><span class="fr-arrow">&rarr;</span><span>Secure funds for your start-up business.</span></li>
                <li><span class="fr-arrow">&rarr;</span><span>Raise funds for your nonprofit.</span></li>
              </ul>
            </div>
          </div>
          {/* Bottom paragraph — brxe-shofck */}
          <p class="fr-bottom-text">
            Kevin is committed to training an army of believers worldwide to multiply kingdom wealth for kingdom impact. Contact us today and let Kevin and his team train you.
          </p>
        </div>
        {/* CTA button — brxe-hhlmjl */}
        <a href="/contact" class="fr-cta">Start Your Fundraising Coaching</a>
      </div>
    </section>

    <!-- Generously Blessed — brxe-ypbgzh -->
    <section class="gb-section">
      <div class="gb-card">
        <h2 class="gb-heading">Generously Blessed</h2>
        <p class="gb-subtext">1 minute devotions that will fire up your spirit. Delivered straight to your inbox.</p>
      </div>
    </section>

    <!-- Magazines — cloned from brxe-xakeuv -->
    <section class="mag-section">
      <div style="width: 1200px; max-width: 100%; margin: 0 auto;">
      <h3 class="mag-heading">Magazines</h3>
      <div class="mag-row">
        {posts.map((post: any) => (
          <div class="mag-card">
            <a href={`/blog/${post.slug}`}>
              <figure class="mag-image-wrap">
                {post.image ? (
                  <img src={`${post.image}?w=1024&h=683&fit=crop&fm=webp&q=80&auto=format`} alt={post.title} class="mag-image" loading="lazy" fetchpriority="low" decoding="async" />
                ) : (
                  <div class="img-placeholder" style="width:100%;height:100%;">{post.title}</div>
                )}
              </figure>
            </a>
            <h4 class="mag-title"><a href={`/blog/${post.slug}`}>{post.title}</a></h4>
          </div>
        ))}
      </div>
      <div class="mag-btn-wrap">
        <a href="/blog" class="mag-btn">View More</a>
      </div>
      </div>
    </section>
  </main>

  <script>
    // Lazy-load autoplay videos — swap data-src to src when near viewport
    const lazyVideos = document.querySelectorAll<HTMLVideoElement>('video.lazy-video');
    if (lazyVideos.length > 0 && 'IntersectionObserver' in window) {
      const loadVideo = (v: HTMLVideoElement) => {
        const sources = v.querySelectorAll<HTMLSourceElement>('source[data-src]');
        if (sources.length === 0) return;
        sources.forEach((s) => {
          if (s.dataset.src) {
            s.src = s.dataset.src;
            s.removeAttribute('data-src');
          }
        });
        v.load();
        v.play().catch(() => {});
      };
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loadVideo(entry.target as HTMLVideoElement);
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px' });
      lazyVideos.forEach((v) => io.observe(v));
    } else {
      // Fallback: load immediately
      lazyVideos.forEach((v) => {
        const sources = v.querySelectorAll<HTMLSourceElement>('source[data-src]');
        sources.forEach((s) => { if (s.dataset.src) { s.src = s.dataset.src; s.removeAttribute('data-src'); } });
        v.load();
      });
    }
  </script>
</Layout>


