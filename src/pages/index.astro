---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';

const books = await sanityClient.fetch(`
  *[_type == "book"] | order(order asc) {
    title,
    "coverImage": coverImage.asset->url
  }
`);

const posts = await sanityClient.fetch(`
  *[_type == "blogPost"] | order(publishDate desc) [0...3] {
    "slug": slug.current,
    title,
    excerpt
  }
`);
---

<Layout title="Kevin White — Author, Speaker, Entrepreneur">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Kevin White",
      "url": "https://kevinwhite.us",
      "jobTitle": "Founder & Chief Spiritual Officer",
      "worksFor": { "@type": "Organization", "name": "Spirit Media" },
      "description": "Serial entrepreneur, bestselling author, conference speaker, and Spirit Media founder.",
      "sameAs": [
        "https://www.youtube.com/@KevinWhiteTV",
        "https://www.instagram.com/kevinwhiteus/",
        "https://www.linkedin.com/in/kevinwhiteus/",
        "https://twitter.com/kevinwhiteus"
      ]
    })}></script>
  </Fragment>

  <main>
    <!-- Hero -->
    <section class="bg-[var(--color-bg-warm)] min-h-[420px] md:min-h-[65vh] flex items-center">
      <div class="container-site py-16 md:py-24 text-center max-w-3xl mx-auto">
        <p class="text-2xl md:text-3xl text-[var(--color-text-light)] mb-2" style="font-family: var(--font-heading);">Hi!</p>
        <h1 class="mb-4">Kevin White</h1>
        <p class="text-lg md:text-xl text-[var(--color-text-light)] leading-relaxed">
          I'm a serial entrepreneur, author, speaker, and Spirit Media founder. Equipping and empowering leaders worldwide to live out God's Word while purposefully generating Kingdom wealth for Kingdom impact.
        </p>
      </div>
    </section>

    <!-- Subscribe CTA -->
    <section class="bg-white py-10 border-b border-[var(--color-border)]">
      <div class="container-site text-center">
        <p class="text-lg text-[var(--color-text-light)] mb-4">Subscribe to get a free pick-me-up devotion</p>
        <a href="/contact" class="btn-gold">Subscribe</a>
      </div>
    </section>

    <!-- Prayer Focus -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site text-center max-w-3xl mx-auto">
        <h2 class="mb-6">Nothing Changes Our Lives More Than Prioritizing Prayer</h2>
        <p class="text-lg text-[var(--color-text-light)] leading-relaxed">
          There is no better way to value what God values, live the life He prescribes, and experience freedom and abundance than prayer. Prayer clarifies our priorities, prayer renews our hope, prayer reshapes us.
        </p>
      </div>
    </section>

    <!-- YouTube -->
    <section class="bg-white section-padding">
      <div class="container-site text-center max-w-2xl mx-auto">
        <span class="eyebrow">YouTube</span>
        <h2 class="mt-3 mb-4">The Kevin White Show</h2>
        <p class="text-[var(--color-text-light)] mb-6">Weekly encouragement and guidance every Tuesday at 10 AM.</p>
        <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="btn-gold">Watch on YouTube</a>
      </div>
    </section>

    <!-- Instagram -->
    <section class="bg-[var(--color-bg-warm)] py-10">
      <div class="container-site text-center">
        <p class="text-lg text-[var(--color-text-light)] mb-4">Follow along on Instagram for daily encouragement</p>
        <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" class="btn-gold">Follow @kevinwhiteus</a>
      </div>
    </section>

    <!-- Three Roles -->
    <section class="bg-white section-padding">
      <div class="container-site">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <div class="text-center">
            <h3 class="mb-3">Serial Entrepreneur</h3>
            <p class="text-[var(--color-text-light)] mb-4">Founded multiple businesses and nonprofits globally. Helped launch hundreds of businesses internationally.</p>
            <a href="/about" class="text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Learn More &rarr;</a>
          </div>
          <div class="text-center">
            <h3 class="mb-3">Conference Speaker</h3>
            <p class="text-[var(--color-text-light)] mb-4">Equips leaders on God's Word, prayer, and kingdom impact. Keynotes that engage, empower, and excite.</p>
            <a href="/speaking" class="text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Learn More &rarr;</a>
          </div>
          <div class="text-center">
            <h3 class="mb-3">Bestselling Author</h3>
            <p class="text-[var(--color-text-light)] mb-4">Seven published books in five years. Each book equips and empowers readers to live out God's Word.</p>
            <a href="/books" class="text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Learn More &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Books Grid -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site text-center">
        <h2 class="mb-8">Books</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-4 max-w-5xl mx-auto">
          {books.map((book: any) => (
            <a href="/books" class="group">
              {book.coverImage ? (
                <img src={`${book.coverImage}?w=200&auto=format`} alt={book.title} class="w-full rounded shadow-md group-hover:shadow-lg transition-shadow" />
              ) : (
                <div class="bg-[var(--color-bg-dark)] rounded aspect-[3/4] flex items-center justify-center shadow-md">
                  <span class="text-xs text-white/40 text-center px-2" style="font-family: var(--font-heading);">{book.title}</span>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Fundraising -->
    <section class="bg-white section-padding">
      <div class="container-site max-w-3xl mx-auto">
        <h2 class="mb-6">Fundraising</h2>
        <p class="text-lg text-[var(--color-text-light)] leading-relaxed mb-4">
          Kevin coaches startups and nonprofits on raising capital. His track record includes guiding nonprofits that have raised over $100M collectively.
        </p>
        <ul class="space-y-2 text-[var(--color-text-light)] mb-6">
          <li class="flex items-start gap-2">
            <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
            Coaching for startup capital and nonprofit donations
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
            Track record: guided nonprofits raising $100M+
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
            Specializes in articulating vision for financial support
          </li>
        </ul>
        <a href="/contact" class="btn-gold">Start Your Fundraising Coaching</a>
      </div>
    </section>

    <!-- Magazines Preview -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site text-center">
        <h2 class="mb-8">Magazines</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow no-underline">
              <div class="h-40 bg-[var(--color-bg-dark)] flex items-center justify-center">
                <span class="text-2xl font-bold text-white/20" style="font-family: var(--font-heading);">{post.title}</span>
              </div>
              <div class="p-5">
                <h3 class="text-lg text-[var(--color-text)] group-hover:text-[var(--color-gold)] transition-colors">{post.title}</h3>
                <p class="text-sm text-[var(--color-text-light)] mt-2 line-clamp-2">{post.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
        <a href="/blog" class="inline-block mt-8 text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">View More &rarr;</a>
      </div>
    </section>
  </main>
</Layout>
