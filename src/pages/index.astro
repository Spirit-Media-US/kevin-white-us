---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';

const books = await sanityClient.fetch(`*[_type == "book"] | order(order asc) { title, "coverImage": coverImage.asset->url }`);
const posts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishDate desc) [0...3] { "slug": slug.current, title, excerpt }`);
---

<Layout title="Kevin White — Author, Speaker, Entrepreneur">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Kevin White",
      "url": "https://kevinwhite.us",
      "jobTitle": "Founder & Chief Spiritual Officer",
      "worksFor": { "@type": "Organization", "name": "Spirit Media" },
      "sameAs": ["https://www.youtube.com/@KevinWhiteTV","https://www.instagram.com/kevinwhiteus/","https://www.linkedin.com/in/kevinwhiteus/","https://twitter.com/kevinwhiteus"]
    })}></script>
  </Fragment>

  <main>
    <!-- Hero -->
    <section class="bg-white section-pad">
      <div class="container-site grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-2xl text-[var(--color-text-light)] mb-1" style="font-family: var(--font-heading);">Hi!</p>
          <h1 class="mb-4">Kevin White</h1>
          <p class="text-lg text-[var(--color-text-light)] leading-relaxed">
            I'm a serial entrepreneur, author, speaker and the founder of Spirit Media.
          </p>
        </div>
        <div class="img-placeholder rounded-lg aspect-[4/3]">Kevin White Photo</div>
      </div>
    </section>

    <!-- Subscribe CTA -->
    <section class="bg-white py-8 text-center border-t border-[var(--color-border)]">
      <div class="container-site">
        <p class="text-[var(--color-text-light)] mb-4">Subscribe to get a free pick-me-up devotion</p>
        <a href="/contact" class="btn btn-primary">Subscribe</a>
      </div>
    </section>

    <!-- Prayer Focus -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div class="img-placeholder rounded-lg aspect-[4/3]">Prayer Image</div>
        <div>
          <h2 class="mb-4 uppercase text-xl" style="font-family: var(--font-body); font-weight: 700; letter-spacing: 0.02em;">Nothing Changes Our Lives More Than Prioritizing Prayer</h2>
          <p class="text-[var(--color-text-light)] leading-relaxed">
            There is no better way to value what God values, live the life He prescribes, and experience freedom and abundance than prayer.
          </p>
        </div>
      </div>
    </section>

    <!-- YouTube -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site text-center max-w-2xl mx-auto">
        <p class="text-lg text-[var(--color-text-light)] leading-relaxed mb-5">
          Stay connected and receive encouragement every week on Kevin's YouTube channel
        </p>
        <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Learn More</a>
      </div>
    </section>

    <!-- Instagram -->
    <section class="bg-white py-10 border-t border-[var(--color-border)]">
      <div class="container-site text-center max-w-2xl mx-auto">
        <p class="text-lg text-[var(--color-text-light)] leading-relaxed mb-5">
          See the latest on Kevin's Instagram page
        </p>
        <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Learn More</a>
      </div>
    </section>

    <!-- Tagline -->
    <section class="bg-white py-10 border-t border-[var(--color-border)]">
      <div class="container-site text-center">
        <p class="text-xl font-bold text-[var(--color-primary)]">Multiplying Kingdom Wealth for Kingdom Good</p>
      </div>
    </section>

    <!-- Serial Entrepreneur -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site max-w-3xl mx-auto">
        <h2 class="mb-4">Serial Entrepreneur</h2>
        <p class="text-[var(--color-text-light)] leading-relaxed mb-5">
          Kevin White is God's startup guy. Driven by the Spirit, his drive for entrepreneurship has pushed him to launch, manage, and succeed in multiple businesses, including Spirit Media, a publishing and marketing company that provides holistic business consulting to amplify your mission. Kevin is a bestselling author who has published seven books in five years. A serial entrepreneur, Kevin has helped launch hundreds of businesses and nonprofits globally.
        </p>
        <a href="https://spiritmedia.us/" target="_blank" rel="noopener noreferrer" class="link-arrow">Learn More &rarr;</a>
      </div>
    </section>

    <!-- Conference Speaker -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site max-w-3xl mx-auto">
        <h2 class="mb-4 uppercase" style="font-family: var(--font-body); font-weight: 700; letter-spacing: 0.02em; font-size: 1.5rem;">Conference Speaker</h2>
        <p class="text-[var(--color-text-light)] leading-relaxed mb-5">
          Kevin is a dynamic conference speaker who equips and empowers leaders to live out God's Word while purposefully generating Kingdom wealth for Kingdom impact. His keynotes are designed to inspire audiences toward creating and living in the presence of God.
        </p>
        <a href="/speaking" class="link-arrow">Learn More &rarr;</a>
      </div>
    </section>

    <!-- Bestselling Author -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site">
        <h2 class="mb-2 text-center">Bestselling Author</h2>
        <p class="text-center text-[var(--color-text-light)] mb-8 max-w-2xl mx-auto">
          Kevin has published seven books in five years. His eighth book will be released in 2025. Each book equips and empowers believers to live out God's Word in their everyday lives.
        </p>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-7 gap-3 max-w-4xl mx-auto">
          {books.map((book: any) => (
            <a href="/books" class="block">
              {book.coverImage ? (
                <img src={`${book.coverImage}?w=200&auto=format`} alt={book.title} class="w-full rounded shadow-sm" />
              ) : (
                <div class="img-placeholder rounded aspect-[3/4] text-[10px]">{book.title}</div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Fundraiser -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site max-w-3xl mx-auto">
        <h2 class="mb-4">Fundraiser</h2>
        <p class="text-[var(--color-text-light)] leading-relaxed mb-4">
          Kevin has personally coached leaders and entrepreneurs in startup capital and nonprofit fundraising. His track record includes guiding organizations that have collectively raised over $100 million.
        </p>
        <ul class="text-[var(--color-text-light)] mb-4 space-y-2 pl-5 list-disc">
          <li>Guided nonprofits raising $100M+</li>
          <li>Coached hundreds of startups internationally</li>
          <li>Specializes in articulating vision for financial support</li>
        </ul>
        <p class="text-[var(--color-text-light)] leading-relaxed mb-6">
          Kevin has mastered the art of articulating and selling vision. He helps leaders express their mission in a way that attracts the financial support they need to fulfill their calling.
        </p>
        <a href="/contact" class="btn btn-primary">Start Your Fundraising Coaching</a>
      </div>
    </section>

    <!-- Blogs -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site">
        <h2 class="mb-6 text-center uppercase" style="font-family: var(--font-body); font-weight: 700; letter-spacing: 0.04em; font-size: 1.25rem;">Blogs</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="block group">
              <div class="img-placeholder rounded-lg aspect-[16/10] mb-3">Blog Image</div>
              <h3 class="text-base font-semibold text-[var(--color-primary)] group-hover:text-[var(--color-gold)]" style="font-family: var(--font-body); transition: color 0.2s;">{post.title}</h3>
            </a>
          ))}
        </div>
        <div class="text-center mt-6">
          <a href="/blog" class="link-arrow">Read More &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Magazines -->
    <section class="bg-white section-pad border-t border-[var(--color-border)]">
      <div class="container-site">
        <h2 class="mb-6 text-center">Magazines</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="block group text-center">
              <div class="img-placeholder rounded-lg aspect-[16/10] mb-3">Magazine Cover</div>
              <h3 class="text-base font-semibold text-[var(--color-primary)]" style="font-family: var(--font-body);">{post.title}</h3>
              <p class="text-sm text-[var(--color-text-light)] mt-1">{post.excerpt}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-6">
          <a href="/blog" class="link-arrow">View More &rarr;</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
