---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';
import { IMG } from '../lib/images.ts';

const books = await sanityClient.fetch(`*[_type == "book"] | order(order asc) { title, "coverImage": coverImage.asset->url }`);
const posts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishDate desc) [0...3] { "slug": slug.current, title, "image": heroImage.asset->url }`);
---

<Layout title="Kevin White — Author, Speaker, Entrepreneur">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "Person", "name": "Kevin White",
      "url": "https://kevinwhite.us", "jobTitle": "Founder & Chief Spiritual Officer",
      "worksFor": { "@type": "Organization", "name": "Spirit Media" },
      "sameAs": ["https://www.youtube.com/@KevinWhiteTV","https://www.instagram.com/kevinwhiteus/","https://www.linkedin.com/in/kevinwhiteus/","https://twitter.com/kevinwhiteus"]
    })}></script>
  </Fragment>

  <main>
    <!-- Hero: background image with prayer text left-aligned -->
    <section
      class="relative bg-cover bg-center flex items-center text-white"
      style={`background-image: url('${IMG.heroBg}?w=1440&auto=format'); height: 100vh;`}
    >
      <div class="container-site relative z-10 py-16">
        <h1 style="font-family: var(--font-heading); font-size: 80px; color: #fff; line-height: 1.05;">
          NOTHING<br />CHANGES<br />OUR LIVES<br />MORE THAN<br />PRIORITIZING PRAYER
        </h1>
      </div>
    </section>

    <!-- Kevin White Quote -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site text-center max-w-4xl mx-auto">
        <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.6; color: var(--color-text);">
          "I have valued prayer my whole life, but when I prioritized prayer above everything else on my calendar I immediately witnessed God's miracles in my life, marriage, family, companies, and world. You can too! Allow me to empower you in prioritizing prayer."
        </p>
        <p style="font-family: var(--font-body); font-size: 16px; margin-top: 12px; color: var(--color-gray);">- Kevin White</p>
      </div>
    </section>

    <!-- YouTube + Instagram: 2 column with background image -->
    <section class="relative bg-cover bg-center" style={`background-image: url('${IMG.ytInstaBg}?w=1920&auto=format'); padding: 4vw 2vw;`}>
      <div class="container-site grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- YouTube -->
        <div style="padding: 2vw;">
          <div class="flex items-center gap-3 mb-4">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-heading); font-size: 20px; color: #fff; display: flex; align-items: center; gap: 8px;">
              Learn More <span>&rarr;</span>
            </a>
          </div>
          <p style="font-family: var(--font-heading); font-size: 30px; line-height: 130%; color: #fff;">
            Stay connected and receive encouragement every week on Kevin's YouTube channel
          </p>
        </div>
        <!-- Instagram -->
        <div style="padding: 2vw;">
          <div class="flex items-center gap-3 mb-4">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" style="font-family: var(--font-heading); font-size: 20px; color: #fff; display: flex; align-items: center; gap: 8px;">
              Learn More <span>&rarr;</span>
            </a>
          </div>
          <p style="font-family: var(--font-heading); font-size: 30px; line-height: 130%; color: #fff;">
            See the latest on Kevin's Instagram page
          </p>
        </div>
      </div>
    </section>

    <!-- Tagline -->
    <section class="bg-white text-center" style="padding: 2vw;">
      <p style="font-family: var(--font-display); font-size: 40px; color: var(--color-black);">
        Multiplying Kingdom Wealth for Kingdom Good
      </p>
    </section>

    <!-- Serial Entrepreneur -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site max-w-4xl mx-auto">
        <h2 style="font-family: var(--font-heading); font-size: 74px; margin-bottom: 20px;">Serial Entrepreneur</h2>
        <p style="font-family: var(--font-body); font-size: 20px; line-height: 1.6; margin-bottom: 20px;">
          Kevin White is God's startup guy. Driven by the Spirit, his drive for entrepreneurship has pushed him to launch, manage, and succeed in multiple businesses, including Spirit Media, a publishing and marketing company that provides holistic business consulting to amplify your mission. Kevin is a bestselling author who has published seven books in five years. A serial entrepreneur, Kevin has helped launch hundreds of businesses and nonprofits globally.
        </p>
        <a href="https://spiritmedia.us/" target="_blank" rel="noopener noreferrer" class="link-more">Learn More &rarr;</a>
      </div>
    </section>

    <!-- Conference Speaker -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site max-w-4xl mx-auto">
        <h2 style="font-family: var(--font-display); font-size: 74px; text-transform: uppercase; margin-bottom: 20px;">Conference Speaker</h2>
        <p style="font-family: var(--font-body); font-size: 20px; line-height: 1.6; margin-bottom: 20px;">
          Kevin is a dynamic conference speaker who equips and empowers leaders to live out God's Word while purposefully generating Kingdom wealth for Kingdom impact. His keynotes are designed to inspire audiences toward creating and living in the presence of God.
        </p>
        <a href="/speaking" class="link-more">Learn More &rarr;</a>
      </div>
    </section>

    <!-- Bestselling Author + Book Covers -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site">
        <h2 style="font-family: var(--font-heading); font-size: 74px; margin-bottom: 10px;">Bestselling Author</h2>
        <p style="font-family: var(--font-body); font-size: 20px; margin-bottom: 30px;">
          Kevin has published seven books in five years. His eighth book will be released in 2025. Each book equips and empowers believers to live out God's Word in their everyday lives.
        </p>
        <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-7 gap-3">
          {books.map((book: any) => (
            <a href="/books" class="block">
              {book.coverImage ? (
                <img src={`${book.coverImage}?w=200&auto=format`} alt={book.title} class="w-full rounded" />
              ) : (
                <div class="img-placeholder rounded aspect-[3/4] text-[10px]">{book.title}</div>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Fundraiser -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site max-w-4xl mx-auto">
        <h2 style="font-family: var(--font-heading); font-size: 74px; margin-bottom: 20px;">Fundraiser</h2>
        <p style="font-family: var(--font-body); font-size: 20px; line-height: 1.6; margin-bottom: 16px;">
          Kevin has personally coached leaders and entrepreneurs in startup capital and nonprofit fundraising. His track record includes guiding organizations that have collectively raised over $100 million.
        </p>
        <ul style="font-family: var(--font-body); font-size: 20px; line-height: 1.6; margin-bottom: 20px; padding-left: 24px; list-style: disc;">
          <li>Guided nonprofits raising $100M+</li>
          <li>Coached hundreds of startups internationally</li>
          <li>Specializes in articulating vision for financial support</li>
        </ul>
        <p style="font-family: var(--font-body); font-size: 20px; line-height: 1.6; margin-bottom: 20px;">
          Kevin has mastered the art of articulating and selling vision. He helps leaders express their mission in a way that attracts the financial support they need to fulfill their calling.
        </p>
        <a href="/contact" class="btn btn-black">Start Your Fundraising Coaching</a>
      </div>
    </section>

    <!-- Blogs: 3 column grid with images -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site">
        <h3 style="font-family: var(--font-display); font-size: 30px; text-transform: uppercase; margin-bottom: 20px;">Blogs</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="block group">
              {post.image ? (
                <img src={`${post.image}?w=600&h=400&fit=crop&auto=format`} alt={post.title} class="w-full aspect-[3/2] object-cover rounded mb-3" />
              ) : (
                <div class="img-placeholder rounded aspect-[3/2] mb-3">{post.title}</div>
              )}
            </a>
          ))}
        </div>
        <div class="mt-4">
          <a href="/blog" class="link-more">Read More &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Magazines: 3 column grid -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site">
        <h3 style="font-family: var(--font-heading); font-size: 30px; margin-bottom: 20px;">Magazines</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="block group text-center">
              {post.image ? (
                <img src={`${post.image}?w=600&h=400&fit=crop&auto=format`} alt={post.title} class="w-full aspect-[3/2] object-cover rounded mb-3" />
              ) : (
                <div class="img-placeholder rounded aspect-[3/2] mb-3">{post.title}</div>
              )}
              <h3 style="font-family: var(--font-body); font-size: 20px;">{post.title}</h3>
            </a>
          ))}
        </div>
        <div class="text-center mt-4">
          <a href="/blog" class="link-more">View More &rarr;</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
