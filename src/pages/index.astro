---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';
import { IMG, VIDEO } from '../lib/images.ts';

const books = await sanityClient.fetch(`*[_type == "book"] | order(order asc) { title, amazonUrl, "coverImage": coverImage.asset->url }`);
const posts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishDate desc) [0...3] { "slug": slug.current, title, "image": heroImage.asset->url }`);
---

<Layout title="Kevin White — Author, Speaker, Entrepreneur" description="Kevin White is a serial entrepreneur, bestselling author, and conference speaker who equips leaders to live out God's Word and prioritize prayer.">
  <Fragment slot="head">
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    <!-- Hero preload gated to desktop. Mobile LCP is the H1 text (performance-gate §6). -->
    <link
      rel="preload"
      as="image"
      href={`${IMG.heroBg}?w=1200&fm=webp&q=80&auto=format`}
      imagesrcset={`${IMG.heroBg}?w=1024&fm=webp&q=78&auto=format 1024w, ${IMG.heroBg}?w=1200&fm=webp&q=80&auto=format 1200w`}
      imagesizes="1200px"
      media="(min-width: 1024px)"
      fetchpriority="high"
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "Person", "name": "Kevin White",
      "url": "https://kevinwhite.us", "jobTitle": "Founder & Chief Spiritual Officer",
      "worksFor": { "@type": "Organization", "name": "Spirit Media" },
      "sameAs": ["https://www.youtube.com/@KevinWhiteTV","https://www.instagram.com/kevinwhiteus/","https://www.linkedin.com/in/kevinwhiteus/","https://twitter.com/kevinwhiteus"]
    })}></script>
  </Fragment>

  <main>
    <!-- Hero: desktop = photo + H1 overlay; mobile = dark gradient + H1 as LCP (performance-gate §6).
         <picture> with media="(min-width:1024px)" on the source so mobile never fetches the real image;
         fallback <img> uses a 1px transparent data URI to avoid any network hit. -->
    <section class="home-hero relative flex items-center text-white">
      <picture class="home-hero-img">
        <source
          media="(min-width: 1024px)"
          srcset={`${IMG.heroBg}?w=1024&fm=webp&q=78&auto=format 1024w, ${IMG.heroBg}?w=1200&fm=webp&q=80&auto=format 1200w`}
          sizes="1200px"
        />
        <img
          src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
          width="1200"
          height="700"
          alt=""
          decoding="async"
        />
      </picture>
      <div class="container-site relative z-10 py-12 md:py-16">
        <h1 class="home-hero-h1">
          NOTHING<br />CHANGES<br />OUR LIVES<br />MORE THAN<br />PRIORITIZING PRAYER
        </h1>
      </div>
    </section>
    <style is:inline>
      /* NOT wrapped in @layer base: global.css has an unlayered
         `h1,h2,h3 { color: #000 }` rule that would otherwise win and
         turn this hero's H1 black. None of these rules touch display/grid
         utilities, so staying unlayered is safe here. */
      .home-hero {
        min-height: clamp(420px, 70vh, 760px);
        height: auto;
        overflow: hidden;
        background: linear-gradient(135deg, #0b1e33 0%, #143054 55%, #0b1e33 100%);
      }
      .home-hero-img {
        display: none;
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
      }
      .home-hero-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }
      @media (min-width: 1024px) {
        .home-hero-img { display: block; }
      }
      .home-hero-h1 {
        /* System-font stack — no webfont fetch, LCP can fire at first paint.
           Lexend causes a 1.5s FCP→LCP gap from font swap/synthesis on
           mobile Slow-4G. This is the LCP element, so it wins the perf
           trade against the 1px of visual difference. */
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: clamp(32px, 9vw, 80px);
        color: #fff;
        line-height: 1.05;
        font-weight: 900;
        letter-spacing: -0.01em;
        text-shadow: 0 2px 18px rgba(0, 0, 0, 0.35);
      }
      @media (max-width: 768px) {
        .home-hero {
          min-height: 420px;
          justify-content: flex-end;
        }
        .home-hero .container-site { text-align: right; }
        .home-hero-h1 { text-align: right; }
      }
      /* Below-fold sections: browser skips layout/paint until scroll nears
         the section → frees main-thread during initial load → faster LCP.
         Size-containment zeros the intrinsic width, so we must force
         width:100% AND specify both inline+block intrinsic sizes. */
      main > section:not(:first-of-type) {
        content-visibility: auto;
        contain-intrinsic-size: 100vw 800px;
        width: 100%;
      }
    </style>

    <!-- Kevin White Quote -->
    <section class="bg-white" style="padding: 3vw 2vw;">
      <div class="container-site text-center max-w-4xl mx-auto">
        <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.6; color: var(--color-text);">
          "I have valued prayer my whole life, but when I prioritized prayer above everything else on my calendar I immediately witnessed God's miracles in my life, marriage, family, companies, and world. You can too! Allow me to empower you in prioritizing prayer."
        </p>
        <p style="font-family: var(--font-body); font-size: 16px; margin-top: 12px; color: var(--color-gray);">- Kevin White</p>
      </div>
    </section>

    <!-- YouTube + Instagram: 2 column with background image -->
    <section class="relative bg-cover bg-center" style={`background-image: url('${IMG.ytInstaBg}?w=1600&fm=webp&q=75&auto=format'); padding: 4vw 2vw;`}>
      <div class="container-site grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- YouTube -->
        <div class="text-center" style="padding: 3vw 2vw;">
          <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube — Kevin White's channel" class="flex items-center justify-center gap-3 mb-4" style="font-family: var(--font-heading); font-size: clamp(16px, 2.5vw, 25px); color: #fff; font-weight: 700; text-transform: uppercase;">
            <svg style="width: 40px; height: 40px; flex-shrink: 0;" fill="white" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <span aria-hidden="true">&rarr;</span> Watch on YouTube
          </a>
          <p style="font-family: var(--font-heading); font-size: 16px; line-height: 150%; color: #fff; text-transform: uppercase; font-weight: 700;">
            Stay connected and receive encouragement every week on Kevin's YouTube channel
          </p>
        </div>
        <!-- Instagram -->
        <div class="text-center" style="padding: 3vw 2vw;">
          <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" aria-label="Follow on Instagram — Kevin White's page" class="flex items-center justify-center gap-3 mb-4" style="font-family: var(--font-heading); font-size: clamp(16px, 2.5vw, 25px); color: #fff; font-weight: 700; text-transform: uppercase;">
            <svg style="width: 40px; height: 40px; flex-shrink: 0;" fill="white" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
            <span aria-hidden="true">&rarr;</span> Follow on Instagram
          </a>
          <p style="font-family: var(--font-heading); font-size: 16px; line-height: 150%; color: #fff; text-transform: uppercase; font-weight: 700;">
            See the latest on Kevin's Instagram page
          </p>
        </div>
      </div>
    </section>

    <!-- Serial Entrepreneur — cloned from live site CSS -->
    <section class="se-section">
      <div style="width: 1200px; max-width: 100%; margin: 0 auto; text-align: center; padding: 4vw 4vw 3vw;">
