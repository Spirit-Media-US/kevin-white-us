---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Page Not Found — Kevin White" description="The page you're looking for doesn't exist. Head back to the Kevin White homepage to keep exploring.">
  <Fragment slot="head"><meta name="robots" content="noindex, nofollow" /></Fragment>
  <main>
    <section class="bg-white min-h-[60vh] flex items-center justify-center">
      <div class="container-site text-center py-20">
        <h1 class="mb-4">404</h1>
        <p class="text-lg text-[var(--color-text-light)] mb-6">Page not found.</p>
        <a href="/" class="btn btn-primary">Go Home</a>
      </div>
    </section>
  </main>
</Layout>
