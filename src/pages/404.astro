---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Page Not Found — Kevin White" description="The page you're looking for doesn't exist.">
  <Fragment slot="head"><meta name="robots" content="noindex, nofollow" /></Fragment>
  <main>
    <section class="bg-[var(--color-bg-warm)] min-h-[60vh] flex items-center justify-center">
      <div class="container-site text-center max-w-2xl mx-auto py-20">
        <span class="eyebrow">404</span>
        <h1 class="mt-4 mb-6">Page Not Found</h1>
        <p class="text-lg text-[var(--color-text-light)] mb-8">
          The page you're looking for doesn't exist or has been moved.
        </p>
        <a href="/" class="btn-gold">Go Home</a>
      </div>
    </section>
  </main>
</Layout>
