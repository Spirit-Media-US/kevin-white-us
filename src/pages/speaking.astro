---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const S = 'https://cdn.sanity.io/images/kwhqwbb4/production';
const heroBg = `${S}/a0ceaa47821f5f9d0bd593c985cf0c1a9fab07dc-2560x1280.jpg`;

const podcasts = [
  `${S}/24fd0338e1c164032bd1dea66ec2aa3049272b53-1024x1024.jpg`,
  `${S}/e9da0869e9081093749da38add1252b1e19e2ef0-640x640.jpg`,
  `${S}/752b4e6401dff674d6a8c5ae8f6de3cf49569d01-1024x1024.jpg`,
  `${S}/369f6154251898ea4b25bdc977804c332c77dbf1-1200x1200.jpg`,
  `${S}/cf13f417117a23de48c279e4893daa0352b82414-2560x2560.jpg`,
  `${S}/0bed2c0be2cc08e94dfc8786560f778f1dabbe1b-1024x1024.jpg`,
  `${S}/0c4a27dd174f51e03d339f8921d1f8569c73ccd3-512x512.png`,
  `${S}/0bed2c0be2cc08e94dfc8786560f778f1dabbe1b-1024x1024.jpg`,
  `${S}/7b19ec60111f26e13215f309f5f17f9485341e4c-800x800.jpg`,
  `${S}/4065752548f94c894f4158415b1d1dd93e444862-640x640.jpg`,
  `${S}/8f7f2d76b81737289d2f775f9620ac3f0521f56b-500x500.jpg`,
  `${S}/6fa96b62b73777f667bcf14fd2a0620470c6cc31-600x600.jpg`,
  `${S}/045603f509fb49e779517c7d242853cd8dfdf697-400x400.jpg`,
  `${S}/6fa96b62b73777f667bcf14fd2a0620470c6cc31-600x600.jpg`,
];

const keynotes = [
  {
    title: 'Living Generous Lives',
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/6-reframe.mp4',
    desc: 'We all want to be more generous, but many fear doing it. It could be a fear of scarcity, exploitation, rejection, stigma, or many other reasons.',
    bullets: [
      'The beginning of the realization that God gives through you is the start of a life of limitless giving.',
      'Learn to enter a relationship with God fueled by courage and characterized by freedom.',
      'Understand how to experience, receive, and give more than you ever thought possible.',
    ],
  },
  {
    title: 'Seeking the Kingdom',
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/2-reframe.mp4',
    desc: "We could study the Bible, go to church, and pray regularly, but if the stress is on finding faith instead of God, we're losing.",
    bullets: [
      "Here, Kevin provides a practical guide on pursuing the presence of God in everyday life, hearing his voice, and receiving his presence.",
      "Understand that God's presence determines your why, what, and how in life.",
      'Learn the six ways the Holy Spirit speaks the word of God.',
      'Get tips on how to improve your spiritual listening.',
    ],
  },
  {
    title: 'A Christian in Entrepreneurship',
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/3-reframe.mp4',
    desc: 'Have you ever wondered how ethical business practices lead to profitability? With a wealth of entrepreneurial experience, Kevin explains the science behind a generosity-driven company.',
    bullets: [
      'Learn how to foster rewarding client relationships and space for growth by being a good steward.',
      'Learn why compassionate business practices succeed and how to implement them into your projects.',
    ],
  },
  {
    title: "God Works, You Don't",
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/8-reframe.mp4',
    desc: 'Often, we are in a tug-of-war between our needs and wants. Especially in a business, this issue magnifies if many employees feel this way.',
    bullets: [
      "As a leader, it's important to remember your part in the Great Commission and how this plays into your commitment to work.",
      'Learn how to reframe your perspective to view work as a fulfilling contribution to the greater good.',
    ],
  },
  {
    title: 'Harness Your Vision',
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/9.mp4',
    desc: 'Being a business leader can entail thinking outside the box. Or, going one further, rejecting the premise of the box to begin with.',
    bullets: [
      'Get tools to rewire your ideation process.',
      'Learn ways to bring your vision to life within a regulated environment.',
      'Learn techniques to harness the power of creative roadblocks.',
    ],
  },
  {
    title: 'The Startup Revolution / Transformational Leadership',
    video: 'https://kevinwhite.us/wp-content/uploads/2024/07/5-reframe.mp4',
    desc: 'How do I start my business? From fundraising to creating a trustworthy, hardworking team, starting from scratch can look like a mountain too tall to climb.',
    bullets: [
      'Learn how to fundraise your business efforts and write a business plan that sells.',
      'Understand the importance of adaptability and how to navigate emerging challenges.',
    ],
  },
];
---

<Layout title="Speaker — Kevin White" description="Book Kevin White for your next conference. Keynotes on generosity, kingdom entrepreneurship, and faith-driven leadership.">
  <main>

    {/* ===== HERO — brxe-ltbwdg ===== */}
    <section class="sp-hero" style={`background-image: url('${heroBg}?w=1920&auto=format');`}>
      <div class="sp-hero-inner">
        <div class="sp-hero-text">
          <h1 class="sp-hero-h1">Engage<br />empower<br />excite</h1>
          <p class="sp-hero-sub">Kevin will move your audience</p>
          <a href="/contact" class="sp-hero-btn">Book Kevin to Speak</a>
        </div>
        <div class="sp-hero-vid">
          <video autoplay loop playsinline muted class="sp-hero-video">
            <source src="https://kevinwhite.us/wp-content/uploads/2024/06/KWI-Speaker-Loop.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </section>

    {/* ===== PODCASTS — brxe-sptqpd ===== */}
    <section class="sp-pods">
      <h2 class="sp-pods-heading">Featured Podcasts</h2>
      <div class="sp-pods-grid">
        {podcasts.map((url, i) => (
          <img src={`${url}?w=200&auto=format`} alt={`Podcast ${i+1}`} class="sp-pod-img" />
        ))}
      </div>
    </section>

    {/* ===== KEYNOTES — brxe-10286d ===== */}
    <section class="sp-keynotes">
      <div class="sp-keynotes-top">
        <h2 class="sp-keynotes-heading">Keynotes</h2>
      </div>
      {keynotes.map((k) => (
        <div class="sp-keynote-row">
          <div class="sp-keynote-vid-col">
            <video autoplay loop playsinline muted class="sp-keynote-video">
              <source src={k.video} type="video/mp4" />
            </video>
          </div>
          <div class="sp-keynote-text-col">
            <h3 class="sp-keynote-title">{k.title}</h3>
            <p class="sp-keynote-desc">{k.desc}</p>
            <ul class="sp-keynote-list">
              {k.bullets.map(b => (
                <li><span class="sp-keynote-arrow">&rarr;</span><span>{b}</span></li>
              ))}
            </ul>
            <a href="/contact" class="sp-keynote-btn">Book</a>
          </div>
        </div>
      ))}
    </section>

    {/* ===== GENEROUSLY BLESSED — brxe-2be012 ===== */}
    <section class="sp-gb">
      <div class="sp-gb-card">
        <h2 class="sp-gb-heading">Generously Blessed</h2>
        <p class="sp-gb-sub">1 minute devotions that will fire up your spirit. Delivered straight to your inbox.</p>
      </div>
    </section>

  </main>
</Layout>

<style is:inline>
  /* === HERO — brxe-ltbwdg === */
  .sp-hero {
    background-size: cover; background-repeat: no-repeat; background-position: center right;
    height: 720px; display: flex; align-items: center; justify-content: center;
    padding: 6vw 4vw;
  }
  .sp-hero-inner {
    width: 1200px; max-width: 100%; display: flex; flex-direction: row; align-items: center;
  }
  .sp-hero-text { flex: 1; padding-left: 20px; display: flex; flex-direction: column; justify-content: center; }
  .sp-hero-h1 {
    font-family: "Black Han Sans", sans-serif; font-weight: 400; font-size: 74px;
    color: #fff; text-transform: uppercase;
  }
  .sp-hero-sub {
    font-family: "Lexend", sans-serif; font-weight: 900; font-size: 30px; color: #fff;
  }
  .sp-hero-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 15px 35px; background-color: #89cff0; color: #fff;
    font-size: 18px; width: 300px; text-decoration: none; margin-top: 40px;
    align-self: flex-start;
  }
  .sp-hero-btn:hover { opacity: 0.85; }
  .sp-hero-vid {
    flex: 1; margin-top: 30px; padding: 10px;
    display: flex; align-items: center; justify-content: center;
  }
  .sp-hero-video {
    width: 100%; aspect-ratio: 1/1; object-fit: cover;
    border: 2px solid #fefefe; align-self: center;
  }

  /* === PODCASTS — brxe-sptqpd === */
  .sp-pods { margin-top: 181px; padding: 0 4vw; }
  .sp-pods-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 50px; text-transform: uppercase; font-weight: 400;
  }
  .sp-pods-grid {
    display: flex; flex-direction: row; flex-wrap: wrap; margin-top: 100px;
    width: 1200px; max-width: 100%; margin-left: auto; margin-right: auto;
  }
  .sp-pod-img {
    width: calc(100% / 7); padding: 20px; object-fit: cover; box-sizing: border-box;
  }

  /* === KEYNOTES — brxe-10286d === */
  .sp-keynotes { padding: 0 4vw 6vw; }
  .sp-keynotes-top {
    align-items: flex-start; padding-top: 100px; padding-right: 4vw;
    padding-bottom: 0; display: flex; flex-direction: column; gap: 30px;
    width: 1200px; max-width: 100%; margin: 0 auto;
  }
  .sp-keynotes-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 50px; text-transform: uppercase; font-weight: 400;
  }
  .sp-keynote-row {
    display: flex; flex-direction: row; padding-top: 3vw; padding-bottom: 3vw;
    border-bottom: 1px solid #d9d9d9;
    width: 1200px; max-width: 100%; margin: 0 auto;
  }
  .sp-keynote-vid-col {
    width: 40%; padding-right: 50px; display: flex; align-items: center;
    justify-content: center; flex-shrink: 0;
  }
  .sp-keynote-video {
    width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 100%;
  }
  .sp-keynote-text-col { width: 70%; }
  .sp-keynote-title {
    font-family: "Lexend", sans-serif; font-weight: 900; font-size: 30px;
    line-height: 48px; color: #000; text-transform: capitalize; margin-bottom: 20px;
    text-align: center;
  }
  .sp-keynote-desc {
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 30px;
    color: #000; margin-bottom: 20px;
  }
  .sp-keynote-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0;
  }
  .sp-keynote-list li {
    font-family: "Almarai", sans-serif; font-size: 18px; color: #000;
    padding: 5px 15px; display: flex; align-items: flex-start; gap: 20px;
  }
  .sp-keynote-arrow { flex-shrink: 0; }
  .sp-keynote-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 15px 35px; background-color: rgba(137,207,240,0.61); color: #fff;
    font-size: 18px; width: 150px; text-decoration: none; margin-top: 40px;
    align-self: flex-start;
  }
  .sp-keynote-btn:hover { opacity: 0.85; }

  /* === GENEROUSLY BLESSED — brxe-2be012 === */
  .sp-gb {
    margin-top: 50px;
    background: url('https://kevinwhite.us/wp-content/uploads/2024/06/KWI-Gradient-1-scaled.jpg') center/cover no-repeat;
    min-height: 700px; display: flex; align-items: center; justify-content: center;
    padding: 4vw 2vw;
  }
  .sp-gb-card {
    background-color: #000; border-radius: 16px; padding: 60px 50px;
    max-width: 700px; width: 100%; text-align: center;
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }
  .sp-gb-heading {
    font-family: "Lexend", sans-serif; font-size: 40px; color: #fff;
    line-height: 50px; margin-bottom: 20px;
  }
  .sp-gb-sub {
    font-family: "Crimson Text", serif; font-size: 25px; color: #fff;
    line-height: 130%; font-weight: 600;
  }

  /* === MOBILE === */
  @media (max-width: 478px) {
    .sp-hero { height: 800px; padding: 0; flex-direction: column-reverse; background-size: auto; background-position: bottom center; }
    .sp-hero-inner { flex-direction: column; justify-content: center; }
    .sp-hero-text { padding: 20px; }
    .sp-hero-h1 { font-size: 40px; }
    .sp-hero-sub { font-size: 19px; margin-top: 10px; }
    .sp-hero-btn { margin-top: 20px; }
    .sp-hero-vid { padding: 10px; }
    .sp-hero-video { aspect-ratio: 1/1; }
    .sp-pods { margin-top: 50px; }
    .sp-pods-heading { font-size: 6vw; padding-left: 20px; }
    .sp-pods-grid { margin-top: 5px; justify-content: center; }
    .sp-pod-img { width: 40%; padding: 10px; }
    .sp-keynotes-top { margin-top: 5vw; padding-top: 0; }
    .sp-keynotes-heading { font-size: 6vw; }
    .sp-keynote-row { flex-direction: column; padding-bottom: 10vw; }
    .sp-keynote-vid-col { width: 100%; padding-right: 0; padding-bottom: 60px; }
    .sp-keynote-text-col { width: 100%; }
    .sp-keynote-title { font-size: 5vw; line-height: 2; margin-top: 20px; }
    .sp-gb { margin-top: 0; padding: 4vw 20px; }
    .sp-gb-card { padding: 40px 24px; }
    .sp-gb-heading { font-size: 30px; }
    .sp-gb-sub { font-size: 20px; }
  }
</style>
