---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Thank You — Kevin White" description="We appreciate your message.">
  <main>
    <section class="bg-white min-h-[60vh] flex items-center justify-center">
      <div class="container-site text-center py-20">
        <h1 class="mb-4">Thank You</h1>
        <p class="text-lg text-[var(--color-text-light)] mb-6">
          We appreciate your effort in providing us with the information we need.
        </p>
        <a href="/" class="btn btn-primary">Go Back Home</a>
      </div>
    </section>
  </main>
</Layout>
