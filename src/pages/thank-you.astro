---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Thank You — Kevin White" description="We appreciate your message.">
  <main>
    <section class="bg-[var(--color-bg-warm)] min-h-[60vh] flex items-center justify-center">
      <div class="container-site text-center max-w-2xl mx-auto py-20">
        <span class="eyebrow">Thank You</span>
        <h1 class="mt-4 mb-6">Message Received</h1>
        <p class="text-lg text-[var(--color-text-light)] mb-8">
          We appreciate your effort in providing us with the information we need. We'll be in touch soon.
        </p>
        <a href="/" class="btn-gold">Go Back Home</a>
      </div>
    </section>
  </main>
</Layout>
