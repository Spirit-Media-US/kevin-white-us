---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Contact — Kevin White" description="Get in touch with Kevin White. Collaborate, book speaking engagements, or subscribe to devotional content.">
  <main>
    <!-- Hero -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <span class="eyebrow">Get in Touch</span>
        <h1 class="mt-4 mb-6">Let's Talk</h1>
        <p class="text-lg text-[var(--color-text-light)] max-w-2xl">
          I enjoy hearing from readers and new friends. Please send a message if you want to collaborate or work together.
        </p>
      </div>
    </section>

    <!-- Contact Content -->
    <section class="bg-white section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl mb-6">Send a Message</h2>
            <form action="/thank-you" method="GET" class="space-y-4">
              <div>
                <label for="name" class="block text-sm font-medium mb-1">Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg bg-[var(--color-bg-warm)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)]" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium mb-1">Email</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg bg-[var(--color-bg-warm)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)]" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium mb-1">Message</label>
                <textarea id="message" name="message" rows="5" required
                  class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg bg-[var(--color-bg-warm)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-gold)]"></textarea>
              </div>
              <button type="submit" class="btn-gold">Send Message</button>
            </form>
          </div>

          <!-- Contact Info -->
          <div>
            <h2 class="text-2xl mb-6">Contact Information</h2>
            <div class="space-y-6">
              <div>
                <h4 class="text-lg mb-2">Mailing Address</h4>
                <p class="text-[var(--color-text-light)]">PO Box 3251<br />Cary, NC 27519</p>
              </div>
              <div>
                <h4 class="text-lg mb-2">Phone</h4>
                <p><a href="tel:+18888578685" class="text-[var(--color-text-light)] no-underline hover:text-[var(--color-gold)]">+1-888-857-8685</a></p>
              </div>
              <div>
                <h4 class="text-lg mb-2">Speaking Inquiries</h4>
                <p class="text-[var(--color-text-light)]">For more on speaking, contact Jeremy:</p>
                <a href="mailto:jeremy@spiritmedia.us" class="font-semibold">jeremy@spiritmedia.us</a>
              </div>
              <div>
                <h4 class="text-lg mb-2">Socials</h4>
                <div class="flex flex-col gap-1 text-[var(--color-text-light)]">
                  <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-gold)]">YouTube — @KevinWhiteTV</a>
                  <a href="https://www.instagram.com/kevinwhiteus/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-gold)]">Instagram — @kevinwhiteus</a>
                  <a href="https://www.linkedin.com/in/kevinwhiteus/" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-gold)]">LinkedIn — @kevinwhiteus</a>
                  <a href="https://twitter.com/kevinwhiteus" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-gold)]">X — @kevinwhiteus</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
