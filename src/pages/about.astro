---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';
import { IMG } from '../lib/images.ts';

const books = await sanityClient.fetch(`*[_type == "book"] | order(order asc) [0...5] { title, "coverImage": coverImage.asset->url, amazonUrl }`);
---

<Layout title="About — Kevin White" description="Kevin White is driven by his deep love for Jesus. Founder of Spirit Media and bestselling author.">
  <main>

    {/* ===== SECTION 1: About Intro — brxe-tqcsmt ===== */}
    <section class="about-intro">
      <div class="about-intro-inner">
        <div class="about-intro-img">
          <img src={`${IMG.kevinCenter}?w=568&auto=format`} alt="Kevin White" class="about-kevin-img" />
        </div>
        <div class="about-intro-text">
          <h1 class="about-heading">About</h1>
          <p class="about-paragraph">
            Kevin White is driven by his deep love for Jesus, his wife, children, and grandchildren. He is the Founder and Chief Spiritual Officer of SpiritMedia.US and owner of White Enterprise. As a serial entrepreneur, bestselling author, and conference speaker, he has helped start hundreds of businesses, churches, and nonprofits worldwide. Through his books, live TV show, and conference speaking events Kevin actively equips and empowers leaders worldwide to live out God's Word while purposefully generating Kingdom wealth for Kingdom impact.
          </p>
          <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="about-btn">In Action</a>
        </div>
      </div>
    </section>

    {/* ===== SECTION 2+3: Key Points + Podcast — brxe-iahcaq + brxe-ysceva ===== */}
    <section class="kp-section">
      {/* Key Points heading */}
      <div class="kp-heading-wrap">
        <h2 class="kp-heading">Key Points</h2>
      </div>

      {/* Image floated right, bullets wrap around it */}
      <div class="kp-content">
        <img src={`${IMG.familyPhoto}?w=800&auto=format`} alt="Kevin with family" class="kp-family-img" />
        <ul class="kp-list">
          <li><span class="kp-icon">&#9786;</span><span>As a serial entrepreneur, Kevin has helped start hundreds of businesses worldwide.</span></li>
          <li><span class="kp-icon">&#9786;</span><span>He has a highly-ranked podcast streaming on all platforms.</span></li>
          <li><span class="kp-icon">&#9786;</span><span>He's the father of three radiant souls.</span></li>
          <li><span class="kp-icon">&#9786;</span><span>He married his high school sweetheart, going thirty years strong.</span></li>
          <li><span class="kp-icon">&#9786;</span><span>In the past twenty years, he has traveled to India four dozen times and traveled to thirty countries.</span></li>
        </ul>
      </div>

    </section>

    {/* ===== PODCAST SECTION — brxe-ysceva / brxe-bnvfwp ===== */}
    <section class="pod-section">
      <h2 class="pod-heading">A Weekly Podcast<br />to Motivate</h2>
      <div class="pod-row">
        <div class="pod-text-col">
          <p class="pod-text">
            Every week since 2020, the Kevin White Show has offered a new idea, proverb, or short story to help listeners prosper in the presence of God.
          </p>
          <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="pod-btn">Listen</a>
        </div>
        <div class="pod-img-col">
          <img src={`${IMG.podcastPhoto}?w=553&auto=format`} alt="A weekly podcast to motivate" class="pod-img" />
        </div>
      </div>
    </section>

    {/* ===== SECTION 4: Services — brxe-scbrek ===== */}
    <section class="about-services">
      <h2 class="about-services-heading">Together, Let's Find a Way</h2>
      <div class="about-services-grid">
        <div class="about-service-card">
          <h3 class="about-service-title">Conference Speaker</h3>
          <p class="about-service-text">Curated keynotes will spark an audience and move them to begin creating and living in the presence of God.</p>
          <a href="/speaking" class="about-service-btn">Learn More</a>
        </div>
        <div class="about-service-card">
          <h3 class="about-service-title">Serial Entrepreneur</h3>
          <p class="about-service-text">Through strategic and results-oriented marketing, Spirit Media is putting businesses on the map every day.</p>
          <a href="https://spiritmediapublishing.com/" target="_blank" rel="noopener noreferrer" class="about-service-btn">Learn More</a>
        </div>
        <div class="about-service-card">
          <h3 class="about-service-title">Fundraiser</h3>
          <p class="about-service-text">These are hands-on workshops for building your business from the ground up with lesson plans, tips, and resources.</p>
          <a href="/contact" class="about-service-btn">Learn More</a>
        </div>
      </div>
    </section>

    {/* ===== SECTION 5: Books — brxe-pxmruk ===== */}
    <section class="ab-books">
      <div class="ab-books-top">
        <h2 class="ab-books-heading">Books</h2>
        <p class="ab-books-sub">Nurture Your Spiritual Journey</p>
        <a href="https://www.amazon.com/stores/author/B08LZYTR2B/allbooks" target="_blank" rel="noopener noreferrer" class="ab-books-btn">View All Books</a>
      </div>
      <div class="ab-books-row">
        <div class="ab-book-block"><img src={`${books.find((b:any)=>b.title==='Get to the Point')?.coverImage}?w=400&auto=format`} alt="Get to the Point" class="ab-book-img" /></div>
        <div class="ab-book-block"><img src={`${IMG.bookAG}?w=400&auto=format`} alt="Audacious Generosity" class="ab-book-img" /></div>
        <div class="ab-book-block"><img src={`${books.find((b:any)=>b.title==='Ultimate Book Marketing Guide')?.coverImage}?w=400&auto=format`} alt="Ultimate Book Marketing Guide" class="ab-book-img" /></div>
        <div class="ab-book-block"><img src={`${books.find((b:any)=>b.title==='Only God Works')?.coverImage}?w=400&auto=format`} alt="Only God Works" class="ab-book-img" /></div>
        <div class="ab-book-block"><img src={`${books.find((b:any)=>b.title?.includes('Your Word'))?.coverImage}?w=400&auto=format`} alt="What's Your Word?" class="ab-book-img" /></div>
      </div>
    </section>

    {/* ===== SECTION 6: Generously Blessed — brxe-b6ac05 ===== */}
    <section class="about-gb">
      <div class="about-gb-card">
        <h2 class="about-gb-heading">Generously Blessed</h2>
        <p class="about-gb-subtext">1 minute devotions that will fire up your spirit. Delivered straight to your inbox.</p>
      </div>
    </section>

  </main>
</Layout>

<style is:inline>
  /* === SECTION 1: About Intro — brxe-tqcsmt === */
  .about-intro { padding-top: 4vw; padding-bottom: 0; }
  .about-intro-inner {
    display: flex; flex-direction: column; align-items: center;
    padding: 0 2vw;
  }
  /* Image block — brxe-wzdzjt: width 60%, centered */
  .about-intro-img {
    width: 60%; display: flex; flex-direction: column; align-items: center;
  }
  .about-kevin-img { width: 100%; max-width: 568px; border-radius: 10px; object-fit: cover; }
  /* Text block — brxe-ceypbc */
  .about-intro-text {
    width: 800px; max-width: 100%; align-self: center; padding-top: 100px; padding-bottom: 4vw;
    display: flex; flex-direction: column; align-items: flex-start;
  }
  .about-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 50px; text-transform: uppercase; font-weight: 400;
  }
  .about-paragraph {
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 30px; color: #000;
    margin-top: 30px; margin-bottom: 20px; text-align: left;
  }
  .about-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 15px 35px; background-color: #88cff1; color: #fff;
    font-size: 18px; width: 300px; text-decoration: none;
  }
  @media (max-width: 478px) {
    .about-intro-img { width: 100%; }
    .about-kevin-img { border-radius: 0; }
    .about-intro-text { width: 100%; padding-top: 50px; padding-right: 20px; padding-left: 20px; margin-left: 0; }
    .about-heading { font-size: 6vw; padding-top: 40px; }
    .about-paragraph { padding: 0; margin-top: 0; }
  }

  /* === SECTION 2+3: Key Points + Podcast — brxe-iahcaq + brxe-ysceva === */
  .kp-section { margin-top: 100px; padding: 6vw 0 8vw; }
  .kp-heading-wrap { padding: 0 2vw; }
  .kp-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 50px; text-transform: uppercase; font-weight: 400;
    margin-top: -16px; margin-left: 50px; text-align: center; margin-bottom: 50px;
  }
  /* Content wrapper */
  .kp-content {
    width: 1200px; max-width: 100%; margin: 0 auto;
    padding: 0 2vw; overflow: hidden;
  }
  /* Image floated right */
  .kp-family-img {
    float: left; width: 50%; height: auto; object-fit: contain;
    margin: 0 30px 30px 0;
  }
  /* List — brxe-iukeaa */
  .kp-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 44px;
  }
  .kp-list li {
    font-family: "Lexend", sans-serif; color: #000; font-size: 25px;
    font-weight: 400; padding: 5px 0 5px 15px;
    display: flex; align-items: flex-start; gap: 20px;
  }
  .kp-icon {
    flex-shrink: 0; font-size: 35px; line-height: 1;
  }

  /* === PODCAST — brxe-ysceva / brxe-bnvfwp === */
  .pod-section {
    padding: 6vw 4vw 4vw;
  }
  .pod-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 90px; text-transform: uppercase; font-weight: 400; text-align: center;
    margin-bottom: 50px;
  }
  .pod-row {
    width: 1200px; max-width: 100%; margin: 0 auto;
    display: flex; flex-direction: row; align-items: stretch;
  }
  .pod-text-col {
    flex: 1; display: flex; flex-direction: column;
    justify-content: center; padding: 0 4vw;
  }
  .pod-text {
    font-family: "Lexend", sans-serif; font-size: 30px; line-height: 48px;
    color: #000; font-weight: 400; margin-bottom: 20px;
  }
  .pod-btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px; color: #fff; padding: 15px 35px;
    background-color: #89cff0; border: none; text-decoration: none;
    align-self: flex-start;
  }
  .pod-btn:hover { opacity: 0.85; }
  .pod-img-col {
    flex: 1; display: flex; align-items: center; justify-content: center;
  }
  .pod-img {
    width: 100%; max-width: 553px; height: auto; object-fit: contain;
  }
  @media (max-width: 478px) {
    .kp-section { margin-top: 50px; }
    .kp-heading { font-size: 6vw; padding-top: 40px; margin-left: 0; }
    .kp-family-img { float: none; width: 100%; max-width: 100%; margin: 0 0 20px 0; }
    .kp-list { gap: 10px; }
    .kp-list li { font-size: 18px; gap: 10px; }
    .pod-section { padding: 4vw; }
    .pod-heading { font-size: 5vw; line-height: 30px; padding-top: 40px; margin-bottom: 30px; }
    .pod-row { flex-direction: column-reverse; }
    .pod-text-col { padding: 20px 0 0; }
    .pod-text { font-size: 20px; line-height: 1.3; }
    .pod-btn { margin-bottom: 50px; }
  }

  /* === SECTION 4: Services — brxe-scbrek === */
  .about-services { padding: 6vw 4vw; }
  .about-services-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 90px; text-transform: uppercase; font-weight: 400; text-align: center;
    margin-bottom: 50px;
  }
  .about-services-grid {
    width: 1200px; max-width: 100%; margin: 0 auto;
    display: flex; flex-direction: row; gap: 20px;
    justify-content: center; align-items: stretch;
  }
  .about-service-card {
    flex: 1; display: flex; flex-direction: column; align-items: center;
    justify-content: space-between;
    background-color: #000; border-radius: 20px;
    padding: 50px 30px 40px; text-align: center;
  }
  .about-service-title {
    font-family: "Lexend", sans-serif; font-size: 30px; color: #fff;
    font-weight: 900; line-height: 48px;
  }
  .about-service-text {
    font-family: "Almarai", sans-serif; font-size: 20px; color: #fff;
    text-align: center; line-height: 130%; font-weight: 400;
    padding: 0 10px; margin-top: 30px;
  }
  .about-service-btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px; color: #fff; padding: 15px 35px;
    background-color: #89cff0; border: none; text-decoration: none;
    margin-top: 30px; border-radius: 0;
  }
  .about-service-btn:hover { opacity: 0.85; }
  @media (max-width: 478px) {
    .about-services { padding: 0 20px 10vw; }
    .about-services-heading { font-size: 5vw; line-height: 50px; padding-top: 40px; }
    .about-services-grid { flex-direction: column; margin-top: 20px; }
    .about-service-title { font-size: 5vw; }
    .about-service-text { font-size: 16px; }
  }

  /* === SECTION 5: Books — brxe-pxmruk === */
  .ab-books { padding: 4vw 4vw 10vw; }
  .ab-books-top {
    display: flex; flex-direction: column; align-items: center;
    padding: 0 4vw 4vw; gap: 30px;
  }
  .ab-books-heading {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    line-height: 90px; text-transform: uppercase; font-weight: 400; text-align: center;
  }
  .ab-books-sub {
    font-family: "Lexend", sans-serif; font-size: 30px; line-height: 48px;
    font-weight: 900; color: #000; margin-bottom: 10px; text-align: center;
  }
  .ab-books-btn {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 18px; color: #fff; padding: 15px 35px;
    background-color: #89cff0; border: none; text-decoration: none;
    margin-bottom: 50px;
  }
  .ab-books-btn:hover { opacity: 0.85; }
  /* Book row — brxe-gslfbz */
  .ab-books-row {
    display: flex; flex-direction: row; gap: 50px; padding-top: 10px;
    justify-content: center; align-items: center;
  }
  .ab-book-block { width: 10%; }
  .ab-book-img {
    width: 100%; height: auto; object-fit: cover;
    transform: rotate(20deg);
  }
  @media (max-width: 478px) {
    .ab-books { padding: 7vw 4vw 15vw; }
    .ab-books-heading { font-size: 6vw; line-height: 10px; }
    .ab-books-sub { font-size: 19px; font-family: "Almarai", sans-serif; font-weight: 800; line-height: 1; text-align: center; }
    .ab-books-row { gap: 20px; flex-wrap: wrap; }
    .ab-book-block { width: 40%; }
    .ab-book-img { transform: rotate(0deg); object-fit: scale-down; }
  }

  /* === SECTION 6: Generously Blessed — brxe-b6ac05 === */
  .about-gb {
    margin-top: 50px;
    background: url('https://cdn.sanity.io/images/kwhqwbb4/production/06946f8ab859ca9d6944c5f0c6d8d733f3ffee3a-2560x1344.jpg') center/cover no-repeat;
    min-height: 700px;
    display: flex; align-items: center; justify-content: center;
    padding: 4vw 2vw;
  }
  .about-gb-card {
    background-color: #000; border-radius: 16px;
    padding: 60px 50px; max-width: 700px; width: 100%;
    text-align: center; box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }
  .about-gb-heading {
    font-family: "Lexend", sans-serif; font-size: 40px; color: #fff;
    line-height: 50px; margin-bottom: 20px;
  }
  .about-gb-subtext {
    font-family: "Crimson Text", serif; font-size: 25px; color: #fff;
    line-height: 130%; font-weight: 600;
  }
  @media (max-width: 478px) {
    .about-gb { padding: 4vw 20px; }
    .about-gb-card { padding: 40px 24px; }
    .about-gb-heading { font-size: 30px; }
    .about-gb-subtext { font-size: 20px; }
  }
</style>
