---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="About — Kevin White" description="Kevin White is driven by his deep love for Jesus, his wife, children, and grandchildren. Founder of Spirit Media and bestselling author.">
  <main>
    <!-- Hero -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <span class="eyebrow">About</span>
        <h1 class="mt-4 mb-6">Kevin White</h1>
        <p class="text-lg md:text-xl text-[var(--color-text-light)] leading-relaxed max-w-3xl">
          Kevin White is driven by his deep love for Jesus, his wife, children, and grandchildren. He is the Founder and Chief Spiritual Officer of SpiritMedia.US and owner of White Enterprise.
        </p>
      </div>
    </section>

    <!-- Bio -->
    <section class="bg-white section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <div class="prose max-w-none">
          <p class="text-lg text-[var(--color-text-light)] leading-relaxed mb-6">
            As a serial entrepreneur and bestselling author, Kevin helps leaders globally equip and empower leaders worldwide to live out God's Word while purposefully generating Kingdom wealth for Kingdom impact.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 my-12">
            <div class="bg-[var(--color-bg-warm)] rounded-lg p-6">
              <h3 class="mb-4">Quick Facts</h3>
              <ul class="space-y-3 text-[var(--color-text-light)]">
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
                  Serial entrepreneur — launched hundreds of businesses internationally
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
                  Hosts a highly-ranked podcast across streaming platforms
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
                  Father of three children
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
                  Married thirty years to his high school sweetheart
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-[var(--color-gold)] mt-1">&#8226;</span>
                  Traveled to India 48 times, visited 30 countries
                </li>
              </ul>
            </div>
            <div class="bg-[var(--color-bg-warm)] rounded-lg p-6">
              <h3 class="mb-4">The Kevin White Show</h3>
              <p class="text-[var(--color-text-light)] mb-4">
                Weekly episodes since 2020 offering ideas, proverbs, and short stories to help listeners prosper in the presence of God.
              </p>
              <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="btn-gold">Watch Now</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <span class="eyebrow">What Kevin Offers</span>
        <h2 class="mt-3 mb-10">Services</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-xl mb-3">Conference Speaker</h3>
            <p class="text-[var(--color-text-light)]">Keynotes designed to inspire audiences toward creating and living in the presence of God.</p>
            <a href="/speaking" class="inline-block mt-4 text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Learn More &rarr;</a>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-xl mb-3">Spirit Media</h3>
            <p class="text-[var(--color-text-light)]">Publishing and marketing services for business visibility. Disrupting the traditional publishing industry.</p>
            <a href="https://spiritmedia.us/" target="_blank" rel="noopener noreferrer" class="inline-block mt-4 text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Visit Site &rarr;</a>
          </div>
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <h3 class="text-xl mb-3">Fundraiser</h3>
            <p class="text-[var(--color-text-light)]">Hands-on workshops and coaching for business development, startup capital, and nonprofit fundraising.</p>
            <a href="/contact" class="inline-block mt-4 text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Get in Touch &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Books -->
    <section class="bg-white section-padding">
      <div class="container-site max-w-4xl mx-auto text-center">
        <span class="eyebrow">Books</span>
        <h2 class="mt-3 mb-4">Nurture Your Spiritual Journey</h2>
        <p class="text-[var(--color-text-light)] mb-8">Seven published books in five years, each equipping readers to live out God's Word.</p>
        <a href="/books" class="btn-gold">View All Books</a>
      </div>
    </section>
  </main>
</Layout>
