---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';

const posts = await sanityClient.fetch(`
  *[_type == "blogPost"] | order(publishDate desc) {
    "slug": slug.current, title, excerpt,
    "author": coalesce(author, "Kevin White"),
    publishDate,
    "image": heroImage.asset->url
  }
`);

const heroBanner = 'https://cdn.sanity.io/images/kwhqwbb4/production/a09ddd320748a47fe35a825a9dcf5179200d1efe-1440x389.jpg';
---

<Layout title="Magazines — Kevin White" description="Quick reads. Powerful results. Devotional articles by Kevin White.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "Blog",
      "name": "Kevin White Magazines", "url": "https://kevinwhite.us/blog",
      "publisher": { "@type": "Person", "name": "Kevin White", "url": "https://kevinwhite.us" }
    })}></script>
  </Fragment>

  <main>
    {/* ===== HERO — brxe-vvdsjq ===== */}
    <section class="mag-hero" style={`background-image: url('${heroBanner}?w=1440&auto=format');`}>
      <div class="mag-hero-inner">
        <h1 class="mag-hero-h1">Magazines</h1>
        <p class="mag-hero-sub">Quick reads. Powerful results.</p>
      </div>
    </section>

    {/* ===== POSTS GRID — brxe-vxrirh ===== */}
    <section class="mag-grid-section">
      <div class="mag-grid-container">
        <div id="mag-grid" class="mag-grid">
          {posts.map((post: any) => (
            <div class="mag-card" data-card>
              <a href={`/blog/${post.slug}`} class="mag-card-link">
                {post.image ? (
                  <img src={`${post.image}?w=600&h=400&fit=crop&auto=format`} alt={post.title} class="mag-card-img" />
                ) : (
                  <div class="img-placeholder mag-card-img">{post.title}</div>
                )}
              </a>
              <h3 class="mag-card-title">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h3>
              {post.excerpt && <p class="mag-card-excerpt">{post.excerpt}</p>}
              <a href={`/blog/${post.slug}`} class="mag-card-readmore">Read more</a>
            </div>
          ))}
        </div>

        {/* Pagination */}
        <div id="mag-pagination" class="mag-pagination"></div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const POSTS_PER_PAGE = 9;
  const cards = Array.from(document.querySelectorAll('[data-card]'));
  const totalPages = Math.ceil(cards.length / POSTS_PER_PAGE);
  let currentPage = 1;

  function render() {
    const start = (currentPage - 1) * POSTS_PER_PAGE;
    const end = start + POSTS_PER_PAGE;
    cards.forEach((card, i) => {
      (card as HTMLElement).style.display = (i >= start && i < end) ? '' : 'none';
    });

    const pag = document.getElementById('mag-pagination');
    if (!pag || totalPages <= 1) return;

    let html = '';
    for (let i = 1; i <= totalPages; i++) {
      html += `<button onclick="goToPage(${i})" class="mag-page-btn ${i === currentPage ? 'active' : ''}">${i}</button>`;
    }
    if (currentPage < totalPages) {
      html += `<button onclick="goToPage(${currentPage + 1})" class="mag-page-btn">&rarr;</button>`;
    }
    pag.innerHTML = html;
  }

  (window as any).goToPage = function(page: number) {
    if (page < 1 || page > totalPages) return;
    currentPage = page;
    render();
    document.getElementById('mag-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  render();
</script>

<style is:inline>
  /* === HERO — brxe-vvdsjq === */
  .mag-hero {
    background-size: cover; background-position: center; background-repeat: no-repeat;
    height: 390px; display: flex; align-items: center; justify-content: center;
  }
  .mag-hero-inner { text-align: center; align-items: center; }
  .mag-hero-h1 {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #fff;
    text-transform: uppercase; font-weight: 400;
  }
  .mag-hero-sub {
    font-family: "Lexend", sans-serif; font-size: 30px; color: #fff;
    line-height: 48px; font-weight: 900;
  }

  /* === GRID — brxe-vxrirh === */
  .mag-grid-section { padding-top: 110px; padding-bottom: 30px; }
  .mag-grid-container {
    width: 1245px; max-width: 100%; margin: 0 auto; padding: 0 4vw;
  }
  .mag-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 105px; margin-bottom: 100px;
  }

  /* === CARD === */
  .mag-card { display: flex; flex-direction: column; }
  .mag-card-link { display: block; }
  .mag-card-img {
    width: 100%; height: 275px; object-fit: cover;
  }
  .mag-card-title {
    font-family: "Almarai", sans-serif; font-size: 20px; font-weight: 800;
    text-transform: uppercase; margin: 20px 0; line-height: 30px;
  }
  .mag-card-title a { color: #000; text-decoration: none; }
  .mag-card-excerpt {
    font-family: "Almarai", sans-serif; font-size: 16px; color: #000;
    line-height: 1.6; margin-bottom: 10px;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .mag-card-readmore {
    font-family: "Almarai", sans-serif; font-size: 15px; font-weight: 800;
    text-transform: uppercase; text-decoration: underline; color: #000;
    margin: 20px 0;
  }

  /* === PAGINATION === */
  .mag-pagination {
    display: flex; justify-content: center; gap: 10px; padding: 20px 0 60px;
  }
  .mag-page-btn {
    font-family: "Almarai", sans-serif; font-size: 16px; font-weight: 700;
    padding: 8px 16px; border: 1px solid #000; background: #fff; color: #000;
    cursor: pointer; transition: all 0.2s;
  }
  .mag-page-btn.active {
    background: #000; color: #fff;
  }
  .mag-page-btn:hover:not(.active) { background: #f0f0f0; }

  /* === MOBILE === */
  @media (max-width: 478px) {
    .mag-hero { padding: 0 40px; }
    .mag-hero-h1 { font-size: 45px; }
    .mag-hero-sub { font-size: 16px; }
    .mag-grid-section { padding-top: 50px; padding-right: 40px; padding-left: 40px; }
    .mag-grid { grid-template-columns: 1fr; gap: 50px; }
  }
</style>
