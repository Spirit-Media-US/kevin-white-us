---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { sanityClient } from '../lib/sanity.ts';

const posts = await sanityClient.fetch(`
  *[_type == "blogPost"] | order(publishDate desc) {
    "slug": slug.current,
    title,
    excerpt,
    "author": coalesce(author, "Kevin White"),
    publishDate
  }
`);

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
}
---

<Layout title="Magazines — Kevin White" description="Quick reads. Powerful results. Kevin White's devotional magazine articles on faith, business, and kingdom impact.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Kevin White Magazines",
      "url": "https://kevinwhite.us/blog",
      "description": "Devotional articles on faith, business, and kingdom impact.",
      "publisher": { "@type": "Person", "name": "Kevin White", "url": "https://kevinwhite.us" }
    })}></script>
  </Fragment>

  <main>
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site max-w-4xl mx-auto">
        <span class="eyebrow">Blog</span>
        <h1 class="mt-4 mb-4">Magazines</h1>
        <p class="text-lg text-[var(--color-text-light)]">Quick reads. Powerful results.</p>
      </div>
    </section>

    <section class="bg-white section-padding">
      <div class="container-site">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post: any) => (
            <a href={`/blog/${post.slug}`} class="group bg-[var(--color-bg-warm)] rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow no-underline">
              <div class="h-48 bg-[var(--color-bg-dark)] flex items-center justify-center">
                <span class="text-3xl font-bold text-white/20" style="font-family: var(--font-heading);">{post.title}</span>
              </div>
              <div class="p-6">
                <p class="text-xs text-[var(--color-text-light)] mb-2">{formatDate(post.publishDate)}</p>
                <h3 class="text-xl mb-3 text-[var(--color-text)] group-hover:text-[var(--color-gold)] transition-colors">{post.title}</h3>
                <p class="text-sm text-[var(--color-text-light)] leading-relaxed">{post.excerpt}</p>
                <span class="inline-block mt-4 text-sm font-semibold text-[var(--color-gold)] uppercase tracking-wider">Read More &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
