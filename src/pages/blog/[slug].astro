---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { sanityClient } from '../../lib/sanity.ts';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]`, { slug });
if (!post) return Astro.redirect('/blog');

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  return blocks.map((block: any) => {
    if (!block || block._type !== 'block') return '';
    const children = Array.isArray(block.children) ? block.children : [];
    const textContent = children.map((child: any) => {
      if (!child) return '';
      let text = child.text || '';
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) text = `<strong>${text}</strong>`;
      if (marks.includes('em')) text = `<em>${text}</em>`;
      return text;
    }).join('');
    const style = block.style || 'normal';
    if (style === 'h2') return `<h2>${textContent}</h2>`;
    if (style === 'h3') return `<h3>${textContent}</h3>`;
    return `<p>${textContent}</p>`;
  }).join('');
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${MONTHS[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
}

const author = post.author || 'Kevin White';
const publishDate = formatDate(post.publishDate);
const bodyHtml = renderPortableText(post.body);
---

<Layout title={`${post.title} — Kevin White`} description={post.seoDescription || post.excerpt || `Read "${post.title}" by Kevin White`}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": post.title,
      "description": post.excerpt || post.title,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Person", "name": "Kevin White", "url": "https://kevinwhite.us" },
      "url": `https://kevinwhite.us/blog/${slug}`,
      "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <main>
    <section class="bg-[var(--color-bg-warm)] section-padding">
      <div class="container-site max-w-3xl mx-auto">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-gold)] no-underline hover:text-[var(--color-gold-dark)] mb-6">&larr; Back to Magazines</a>
        <h1>{post.title}</h1>
        <div class="flex items-center gap-3 mt-4 text-sm text-[var(--color-text-light)]">
          <span>By <strong class="text-[var(--color-text)]">{author}</strong></span>
          <span>&middot;</span>
          <span>{publishDate}</span>
        </div>
      </div>
    </section>

    <section class="bg-white section-padding">
      <div class="container-site max-w-3xl mx-auto">
        <div class="prose-content" set:html={bodyHtml} />
      </div>
    </section>

    <section class="bg-[var(--color-bg-dark)] text-white section-padding">
      <div class="container-site text-center max-w-2xl mx-auto">
        <p class="text-[var(--color-text-muted)] mb-2">Watch The Kevin White Show</p>
        <h2 class="text-white mb-6">Every Tuesday at 10 AM on YouTube</h2>
        <a href="https://www.youtube.com/@KevinWhiteTV" target="_blank" rel="noopener noreferrer" class="btn-gold">Watch Now</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .prose-content :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-content :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content :global(p) {
    color: var(--color-text-light);
    font-size: 1.125rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .prose-content :global(strong) {
    color: var(--color-text);
  }
  .prose-content :global(em) {
    color: var(--color-text);
  }
</style>
