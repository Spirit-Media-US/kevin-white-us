---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { sanityClient, urlFor } from '../../lib/sanity.ts';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import BlogCommentForm from '../../components/BlogCommentForm.astro';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(
  `*[_type == "blogPost" && slug.current == $slug][0]{
    title, excerpt, author, publishDate, tags, body, seoTitle, seoDescription,
    heroImage, "heroUrl": heroImage.asset->url
  }`,
  { slug },
);
if (!post) return Astro.redirect('/blog');

function renderChildren(children: any[], markDefs: any[]): string {
  return children
    .map((child: any) => {
      if (!child) return '';
      let text = (child.text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) text = `<strong>${text}</strong>`;
      if (marks.includes('em')) text = `<em>${text}</em>`;
      for (const m of marks) {
        const def = markDefs.find((d: any) => d._key === m);
        if (def?._type === 'link' && def.href) {
          text = `<a href="${def.href}" target="_blank" rel="noopener noreferrer" class="bp-link">${text}</a>`;
        }
      }
      return text;
    })
    .join('');
}

function renderBlockContent(block: any): string {
  const children = Array.isArray(block.children) ? block.children : [];
  const markDefs = Array.isArray(block.markDefs) ? block.markDefs : [];
  return renderChildren(children, markDefs);
}

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  let html = '';
  let openList: { tag: 'ul' | 'ol' } | null = null;

  const closeList = () => {
    if (openList) { html += `</${openList.tag}>`; openList = null; }
  };

  for (const block of blocks) {
    if (!block || block._type !== 'block') continue;
    const rawText = (block.children || []).map((c: any) => c?.text || '').join('').trim();
    if (!rawText) continue;
    if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText)) continue;

    // List blocks
    if (block.listItem === 'bullet' || block.listItem === 'number') {
      const wantTag: 'ul' | 'ol' = block.listItem === 'number' ? 'ol' : 'ul';
      if (!openList || openList.tag !== wantTag) {
        closeList();
        html += `<${wantTag} class="bp-${wantTag}">`;
        openList = { tag: wantTag };
      }
      html += `<li class="bp-li">${renderBlockContent(block)}</li>`;
      continue;
    }
    closeList();

    const content = renderBlockContent(block);
    const style = block.style || 'normal';
    if (style === 'scripture') html += `<h3 class="bp-scripture">${content}</h3>`;
    else if (style === 'h2') html += `<h2 class="bp-h2">${content}</h2>`;
    else if (style === 'h3') html += `<h3 class="bp-h3">${content}</h3>`;
    else if (style === 'blockquote') html += `<blockquote class="bp-quote">${content}</blockquote>`;
    else html += `<p class="bp-p">${content}</p>`;
  }
  closeList();
  return html;
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  if (!d) return '';
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const author = post.author || 'Kevin White';
const publishDate = formatDate(post.publishDate);
const tags: string[] = post.tags || [];
const heroImage = post.heroImage
  ? urlFor(post.heroImage).width(1600).format('webp').url()
  : post.heroUrl || null;
const bodyHtml = renderPortableText(post.body);
const canonical = `https://kevinwhite.us/blog/${slug}`;
---

<Layout
  title={post.seoTitle || `${post.title} — Kevin White`}
  description={post.seoDescription || post.excerpt || `Read "${post.title}" by Kevin White`}
  ogImage={heroImage || undefined}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BlogPosting",
      "headline": post.title, "description": post.excerpt || post.title,
      "image": heroImage || undefined,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Person", "name": "Kevin White", "url": "https://kevinwhite.us" },
      "url": canonical, "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <main>

    {heroImage && (
      <div class="bp-hero-img-wrap" data-animate="fade-up">
        <img src={heroImage} alt={post.heroImage?.alt || post.title} class="bp-hero-img" />
      </div>
    )}

    <section class="bp-header" data-animate="fade-up">
      <div class="bp-header-inner">
        <a href="/blog" class="bp-back">&larr; Back to Magazines</a>
        <h1 class="bp-title">{post.title}</h1>
        {post.excerpt && <p class="bp-excerpt">{post.excerpt}</p>}
        <div class="bp-meta">
          <span>By <strong>{author}</strong></span>
          {publishDate && <><span>&middot;</span><span>{publishDate}</span></>}
        </div>
        {tags.length > 0 && (
          <div class="bp-tags">
            {tags.map((t: string) => (
              <a href={`/blog?tag=${encodeURIComponent(t)}`} class="bp-tag">{t}</a>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="bp-content" data-animate="fade-up">
      <div class="bp-content-inner" set:html={bodyHtml} />
    </section>

    <ShareBar title={post.title} url={canonical} />

    <BlogCommentForm postTitle={post.title} />

    <RelatedPosts currentSlug={`/blog/${slug}`} currentTags={tags} />

  </main>
</Layout>

<style is:inline>
  /* Blog post — styles matched 1:1 with kevinwhite.us/<slug>/ (Bricks theme).
     Live values:
       body font-size 20px, line-height 30px (1.5), text-align justify, Almarai
       post-content margin 50px top/bottom, plus 100px wp-block-spacer
       title H1 74px Black Han Sans, mobile 45px
       body on mobile: 18px, text-align left                                 */

  /* HERO IMAGE */
  .bp-hero-img-wrap { width: 100%; max-height: 600px; overflow: hidden; }
  .bp-hero-img { width: 100%; height: 100%; max-height: 600px; object-fit: cover; display: block; }

  /* HEADER */
  .bp-header { background: #fff; padding: 100px 4vw 40px; }
  .bp-header-inner { width: 900px; max-width: 100%; margin: 0 auto; }
  .bp-back {
    display: inline-block;
    font-family: "Almarai", sans-serif; font-size: 14px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1px; color: #000;
    text-decoration: none; margin-bottom: 40px;
    transition: opacity 0.2s;
  }
  .bp-back:hover { opacity: 0.6; }
  .bp-title {
    font-family: "Black Han Sans", sans-serif; font-size: 74px; color: #000;
    text-transform: uppercase; font-weight: 400; line-height: 1; margin: 0 0 24px;
  }
  .bp-excerpt {
    font-family: "Lexend", sans-serif; font-size: 30px; font-weight: 900;
    color: #000; line-height: 48px; margin: 0 0 32px;
  }
  .bp-meta {
    display: flex; gap: 10px; align-items: center;
    font-family: "Almarai", sans-serif; font-size: 16px; color: #666;
    padding-bottom: 32px; border-bottom: 1px solid #e5e5e5;
  }
  .bp-meta strong { color: #000; }
  .bp-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
  .bp-tag {
    font-family: "Almarai", sans-serif; font-size: 13px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 0.5px;
    background: #f0ecdf; color: #555; padding: 6px 14px; border-radius: 999px;
    text-decoration: none; transition: all 0.15s;
  }
  .bp-tag:hover { background: #000; color: #fff; }

  /* CONTENT — faithful to live Bricks .brxe-post-content rules */
  .bp-content { background: #fff; padding: 50px 4vw 100px; }
  .bp-content-inner {
    width: 900px; max-width: 100%; margin: 0 auto;
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 30px;
    color: #000; text-align: justify;
  }

  /* Paragraphs — live uses normal block margins + plenty of vertical air */
  .bp-content-inner :global(.bp-p) {
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 30px;
    color: #000; margin: 0 0 30px;
  }

  /* Scripture heading (was an <h1> in the WordPress source) — big + airy,
     matching the live site's generous title/verse rhythm */
  .bp-content-inner :global(.bp-scripture) {
    font-family: "Black Han Sans", sans-serif; font-weight: 400;
    font-size: 40px; line-height: 1.15; text-transform: uppercase;
    color: #000; text-align: left;
    margin: 80px 0 30px; padding: 0;
  }
  .bp-content-inner :global(.bp-scripture + .bp-p) {
    font-family: "Almarai", sans-serif; font-style: italic; font-size: 20px;
    line-height: 30px; color: #000; margin: 0 0 30px; text-align: left;
  }

  /* Secondary headings, rarely used */
  .bp-content-inner :global(.bp-h2) {
    font-family: "Black Han Sans", sans-serif; font-weight: 400;
    font-size: 40px; color: #000; text-transform: uppercase;
    line-height: 1.15; text-align: left;
    margin: 80px 0 30px;
  }
  .bp-content-inner :global(.bp-h3) {
    font-family: "Almarai", sans-serif; font-size: 24px; font-weight: 800;
    color: #000; letter-spacing: 0.3px; line-height: 36px;
    text-align: left; margin: 60px 0 20px;
  }

  /* Blockquote — minimal, Bricks style */
  .bp-content-inner :global(.bp-quote) {
    font-family: "Almarai", sans-serif; font-style: italic;
    font-size: 20px; line-height: 30px; color: #000;
    border-left: 4px solid #000; padding: 6px 0 6px 24px;
    margin: 40px 0; text-align: left;
  }

  /* Lists — use the same 20px/30px rhythm as paragraphs */
  .bp-content-inner :global(.bp-ul),
  .bp-content-inner :global(.bp-ol) {
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 30px;
    color: #000; text-align: left;
    margin: 0 0 40px; padding-left: 32px;
  }
  .bp-content-inner :global(.bp-ul) { list-style: disc; }
  .bp-content-inner :global(.bp-ol) { list-style: decimal; }
  .bp-content-inner :global(.bp-li) { margin: 0 0 16px; padding-left: 6px; }

  .bp-content-inner :global(.bp-link) { color: #000; text-decoration: underline; }
  .bp-content-inner :global(.bp-link:hover) { opacity: 0.7; }
  .bp-content-inner :global(strong) { color: #000; font-weight: 800; }

  /* MOBILE — live mobile: font-size 18px, text-align left */
  @media (max-width: 700px) {
    .bp-hero-img-wrap { max-height: 360px; }
    .bp-hero-img { max-height: 360px; }
    .bp-header { padding: 50px 20px 30px; }
    .bp-title { font-size: 45px; }
    .bp-excerpt { font-size: 16px; line-height: 1.5; }

    .bp-content { padding: 30px 20px 60px; }
    .bp-content-inner { font-size: 18px; line-height: 1.6; text-align: left; }
    .bp-content-inner :global(.bp-p),
    .bp-content-inner :global(.bp-scripture + .bp-p),
    .bp-content-inner :global(.bp-ul),
    .bp-content-inner :global(.bp-ol),
    .bp-content-inner :global(.bp-quote) {
      font-size: 18px; line-height: 1.6;
    }
    .bp-content-inner :global(.bp-p) { margin-bottom: 24px; }
    .bp-content-inner :global(.bp-scripture),
    .bp-content-inner :global(.bp-h2) { font-size: 28px; margin: 50px 0 20px; }
    .bp-content-inner :global(.bp-h3) { font-size: 20px; margin: 40px 0 16px; }
  }
</style>
