---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { sanityClient, urlFor } from '../../lib/sanity.ts';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareBar from '../../components/ShareBar.astro';
import BlogCommentForm from '../../components/BlogCommentForm.astro';

export async function getStaticPaths() {
  const posts = await sanityClient.fetch(`*[_type == "blogPost"] { "slug": slug.current }`);
  return posts.map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch(
  `*[_type == "blogPost" && slug.current == $slug][0]{
    title, excerpt, author, publishDate, tags, body, seoTitle, seoDescription,
    heroImage, "heroUrl": heroImage.asset->url
  }`,
  { slug },
);
if (!post) return Astro.redirect('/blog');

function renderChildren(children: any[], markDefs: any[]): string {
  return children
    .map((child: any) => {
      if (!child) return '';
      let text = (child.text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
      const marks = Array.isArray(child.marks) ? child.marks : [];
      if (marks.includes('strong')) text = `<strong>${text}</strong>`;
      if (marks.includes('em')) text = `<em>${text}</em>`;
      for (const m of marks) {
        const def = markDefs.find((d: any) => d._key === m);
        if (def?._type === 'link' && def.href) {
          text = `<a href="${def.href}" target="_blank" rel="noopener noreferrer" class="bp-link">${text}</a>`;
        }
      }
      return text;
    })
    .join('');
}

function renderBlockContent(block: any): string {
  const children = Array.isArray(block.children) ? block.children : [];
  const markDefs = Array.isArray(block.markDefs) ? block.markDefs : [];
  return renderChildren(children, markDefs);
}

function renderPortableText(blocks: any[]): string {
  if (!Array.isArray(blocks)) return '';
  let html = '';
  let openList: { tag: 'ul' | 'ol' } | null = null;

  const closeList = () => {
    if (openList) { html += `</${openList.tag}>`; openList = null; }
  };

  for (const block of blocks) {
    if (!block || block._type !== 'block') continue;
    const rawText = (block.children || []).map((c: any) => c?.text || '').join('').trim();
    if (!rawText) continue;
    if (/^\{[\w]+\}\s*[—–-]\s*\{[\w]+\}$/.test(rawText)) continue;

    // List blocks
    if (block.listItem === 'bullet' || block.listItem === 'number') {
      const wantTag: 'ul' | 'ol' = block.listItem === 'number' ? 'ol' : 'ul';
      if (!openList || openList.tag !== wantTag) {
        closeList();
        html += `<${wantTag} class="bp-${wantTag}">`;
        openList = { tag: wantTag };
      }
      html += `<li class="bp-li">${renderBlockContent(block)}</li>`;
      continue;
    }
    closeList();

    const content = renderBlockContent(block);
    const style = block.style || 'normal';
    if (style === 'scripture') html += `<h3 class="bp-scripture">${content}</h3>`;
    else if (style === 'h2') html += `<h2 class="bp-h2">${content}</h2>`;
    else if (style === 'h3') html += `<h3 class="bp-h3">${content}</h3>`;
    else if (style === 'blockquote') html += `<blockquote class="bp-quote">${content}</blockquote>`;
    else html += `<p class="bp-p">${content}</p>`;
  }
  closeList();
  return html;
}

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const formatDate = (d: string) => {
  if (!d) return '';
  const dt = new Date(d);
  return `${MONTHS[dt.getUTCMonth()]} ${dt.getUTCDate()}, ${dt.getUTCFullYear()}`;
};

const author = post.author || 'Kevin White';
const publishDate = formatDate(post.publishDate);
const tags: string[] = post.tags || [];
const heroImage = post.heroImage
  ? urlFor(post.heroImage).width(1600).format('webp').url()
  : post.heroUrl || null;
const bodyHtml = renderPortableText(post.body);
const canonical = `https://kevinwhite.us/blog/${slug}`;
---

<Layout
  title={post.seoTitle || `${post.title} — Kevin White`}
  description={post.seoDescription || post.excerpt || `Read "${post.title}" by Kevin White`}
  ogImage={heroImage || undefined}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:author" content={author} />
    <meta property="article:published_time" content={post.publishDate} />
    {tags.length > 0 && <meta property="article:section" content={tags[0]} />}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BlogPosting",
      "headline": post.title, "description": post.excerpt || post.title,
      "image": heroImage || undefined,
      "author": { "@type": "Person", "name": author },
      "publisher": { "@type": "Person", "name": "Kevin White", "url": "https://kevinwhite.us" },
      "url": canonical, "datePublished": post.publishDate
    })}></script>
  </Fragment>

  <main class="bp-root">

    {heroImage && (
      <div class="bp-hero-img-wrap">
        <img src={heroImage} alt={post.heroImage?.alt || post.title} class="bp-hero-img" />
        <div class="bp-hero-fade" aria-hidden="true"></div>
      </div>
    )}

    <section class="bp-header">
      <div class="bp-header-inner" data-animate="fade-up">
        <a href="/blog" class="bp-back">
          <span class="bp-back-arrow">&larr;</span> Back to Magazines
        </a>

        <p class="bp-eyebrow">{tags[0] || 'Magazine'}</p>

        <h1 class="bp-title">{post.title}</h1>

        {post.excerpt && <p class="bp-excerpt">{post.excerpt}</p>}

        <div class="bp-meta-row">
          <div class="bp-author-chip">
            <span class="bp-author-avatar">{author.charAt(0)}</span>
            <span class="bp-author-name">{author}</span>
          </div>
          {publishDate && (
            <div class="bp-meta-group">
              <span class="bp-meta-dot" aria-hidden="true"></span>
              <span class="bp-meta-date">{publishDate}</span>
            </div>
          )}
        </div>

        <div class="bp-rule" aria-hidden="true"></div>

        {tags.length > 0 && (
          <div class="bp-tags">
            {tags.map((t: string) => (
              <a href={`/blog?tag=${encodeURIComponent(t)}`} class="bp-tag">{t}</a>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="bp-content">
      <article class="bp-content-inner" data-animate="fade-up" set:html={bodyHtml} />
    </section>

    <ShareBar title={post.title} url={canonical} />

    <BlogCommentForm postTitle={post.title} />

    <RelatedPosts currentSlug={`/blog/${slug}`} currentTags={tags} />

  </main>
</Layout>

<style is:inline>
  /* =========================================================================
     Blog post — polished editorial layout
     ---------------------------------------------------------------------------
     Color: neutral whites + #faf6ed cream + gold (#c9b36b) accent. Matches the
     "Generously Blessed" gradient palette used elsewhere on the site.
     Widths:
        header container  820px (generous for the big title + meta)
        article body      720px (narrower for comfortable reading rhythm)
        share / comments  720px (aligned with body column)
     ========================================================================== */

  .bp-root { background: #fff; color: #1c1c1c; }

  /* ---------- HERO ---------- */
  .bp-hero-img-wrap { position: relative; width: 100%; max-height: 640px; overflow: hidden; background: #f4f1e8; }
  .bp-hero-img {
    width: 100%; height: 100%; max-height: 640px; object-fit: cover; display: block;
    transform: scale(1.02); transition: transform 12s ease-out;
  }
  .bp-hero-img-wrap:hover .bp-hero-img { transform: scale(1.06); }
  .bp-hero-fade {
    position: absolute; inset: auto 0 0 0; height: 120px; pointer-events: none;
    background: linear-gradient(to bottom, transparent 0%, #fff 100%);
  }

  /* ---------- HEADER ---------- */
  .bp-header { background: #fff; padding: 64px 4vw 40px; }
  .bp-header-inner { width: 820px; max-width: 100%; margin: 0 auto; text-align: center; }

  .bp-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: "Almarai", sans-serif; font-size: 12px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1.5px; color: #666;
    text-decoration: none; margin-bottom: 40px;
  }
  .bp-back:hover { color: #000; }
  .bp-back:hover .bp-back-arrow { transform: translateX(-3px); }
  .bp-back-arrow { display: inline-block; transition: transform 0.2s ease; }

  .bp-eyebrow {
    font-family: "Almarai", sans-serif; font-size: 12px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 3px; color: #c9b36b;
    margin: 0 0 16px;
  }

  .bp-title {
    font-family: "Black Han Sans", sans-serif; font-weight: 400;
    font-size: clamp(44px, 7vw, 88px); color: #0a0a0a;
    text-transform: uppercase; line-height: 0.95; letter-spacing: -0.01em;
    margin: 0 0 24px;
  }

  .bp-excerpt {
    font-family: "Lexend", sans-serif; font-size: 21px; font-weight: 400;
    color: #555; line-height: 1.55; letter-spacing: -0.005em;
    margin: 0 auto 36px; max-width: 640px;
  }

  .bp-meta-row {
    display: inline-flex; align-items: center; gap: 16px; flex-wrap: wrap;
    justify-content: center; margin-bottom: 32px;
  }
  .bp-author-chip { display: inline-flex; align-items: center; gap: 10px; }
  .bp-author-avatar {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    background: #0a0a0a; color: #fff;
    font-family: "Black Han Sans", sans-serif; font-size: 16px;
  }
  .bp-author-name {
    font-family: "Almarai", sans-serif; font-size: 14px; font-weight: 800;
    color: #000; letter-spacing: 0.3px;
  }
  .bp-meta-group { display: inline-flex; align-items: center; gap: 12px; }
  .bp-meta-dot { width: 4px; height: 4px; border-radius: 50%; background: #c9b36b; }
  .bp-meta-date {
    font-family: "Almarai", sans-serif; font-size: 13px; color: #777;
    letter-spacing: 0.5px; text-transform: uppercase;
  }

  .bp-rule {
    width: 48px; height: 3px; background: #c9b36b;
    margin: 0 auto 28px; border-radius: 2px;
  }

  .bp-tags { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
  .bp-tag {
    font-family: "Almarai", sans-serif; font-size: 11px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1px;
    background: transparent; color: #777;
    padding: 6px 14px; border: 1px solid #e2ddce; border-radius: 999px;
    text-decoration: none; transition: all 0.2s ease;
  }
  .bp-tag:hover { background: #0a0a0a; color: #fff; border-color: #0a0a0a; }

  /* ---------- BODY CONTENT ---------- */
  .bp-content { background: #fff; padding: 24px 4vw 80px; }
  .bp-content-inner { width: 720px; max-width: 100%; margin: 0 auto; }

  .bp-content-inner :global(.bp-p) {
    font-family: "Almarai", sans-serif; font-size: 20px; font-weight: 400;
    line-height: 1.85; color: #1c1c1c;
    margin: 0 0 32px;
  }

  /* Elegant drop cap on the very first paragraph */
  .bp-content-inner > :global(.bp-p:first-child::first-letter) {
    font-family: "Black Han Sans", sans-serif;
    font-size: 4.2em; line-height: 0.82; font-weight: 400;
    float: left; margin: 10px 14px 0 0; color: #c9b36b;
  }

  .bp-content-inner :global(.bp-h2) {
    font-family: "Black Han Sans", sans-serif; font-weight: 400;
    font-size: 40px; color: #0a0a0a;
    text-transform: uppercase; line-height: 1.1; letter-spacing: -0.005em;
    margin: 64px 0 20px; position: relative;
  }
  .bp-content-inner :global(.bp-h2::after) {
    content: ""; display: block; width: 36px; height: 3px;
    background: #c9b36b; margin-top: 14px; border-radius: 2px;
  }

  .bp-content-inner :global(.bp-h3) {
    font-family: "Almarai", sans-serif; font-size: 14px; font-weight: 800;
    color: #0a0a0a; text-transform: uppercase; letter-spacing: 2.5px;
    margin: 44px 0 14px;
  }

  /* Pull-quote — big, centered, Lexend italic with opening quote glyph */
  .bp-content-inner :global(.bp-quote) {
    position: relative;
    font-family: "Lexend", sans-serif; font-size: 26px; font-weight: 400;
    font-style: italic; color: #0a0a0a; line-height: 1.45;
    text-align: center;
    padding: 40px 0; margin: 48px 0;
    border-top: 1px solid #e8e2cf; border-bottom: 1px solid #e8e2cf;
  }
  .bp-content-inner :global(.bp-quote::before) {
    content: "\201C"; position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    width: 40px; height: 40px; background: #fff;
    font-family: "Black Han Sans", sans-serif; font-size: 40px; font-style: normal;
    line-height: 1; color: #c9b36b;
    display: flex; align-items: center; justify-content: center;
  }

  /* Scripture — a cream card with gold side rule + subtle quote glyph */
  .bp-content-inner :global(.bp-scripture) {
    position: relative;
    font-family: "Black Han Sans", sans-serif; font-weight: 400;
    font-size: 18px; letter-spacing: 1.2px; text-transform: uppercase;
    color: #0a0a0a; line-height: 1.3;
    margin: 52px 0 0; padding: 24px 28px 24px 32px;
    background: #faf6ed; border-radius: 4px;
    border-left: 4px solid #c9b36b;
    box-shadow: 0 1px 0 #eee7d3;
  }
  .bp-content-inner :global(.bp-scripture + .bp-p) {
    font-family: "Lexend", sans-serif; font-style: italic; font-weight: 400;
    font-size: 20px; line-height: 1.7; color: #2a2a2a;
    background: #faf6ed; border-radius: 0 0 4px 4px;
    margin: 0 0 36px; padding: 0 32px 28px;
    border-left: 4px solid #c9b36b;
  }

  /* Lists — refined markers + spacing */
  .bp-content-inner :global(.bp-ul),
  .bp-content-inner :global(.bp-ol) {
    margin: 0 0 32px; padding-left: 28px;
    font-family: "Almarai", sans-serif; font-size: 20px; line-height: 1.85; color: #1c1c1c;
  }
  .bp-content-inner :global(.bp-ul) { list-style: none; padding-left: 4px; }
  .bp-content-inner :global(.bp-ol) { list-style: decimal; padding-left: 28px; }
  .bp-content-inner :global(.bp-li) { margin: 0 0 12px; padding-left: 0; position: relative; }
  .bp-content-inner :global(.bp-ul .bp-li) { padding-left: 26px; }
  .bp-content-inner :global(.bp-ul .bp-li::before) {
    content: ""; position: absolute; top: 14px; left: 0;
    width: 10px; height: 10px; border-radius: 50%;
    background: #c9b36b;
  }
  .bp-content-inner :global(.bp-ol .bp-li::marker) { color: #c9b36b; font-weight: 800; }

  .bp-content-inner :global(.bp-link) {
    color: #0a0a0a; text-decoration: none;
    background-image: linear-gradient(to right, #c9b36b, #c9b36b);
    background-size: 100% 1px; background-repeat: no-repeat; background-position: 0 100%;
    padding-bottom: 2px; transition: background-size 0.2s ease, color 0.2s ease;
  }
  .bp-content-inner :global(.bp-link:hover) { background-size: 100% 100%; color: #0a0a0a; padding-bottom: 2px; }

  .bp-content-inner :global(strong) { color: #0a0a0a; font-weight: 800; }
  .bp-content-inner :global(em) { font-style: italic; color: #333; }

  /* ---------- MOBILE ---------- */
  @media (max-width: 760px) {
    .bp-hero-img-wrap { max-height: 380px; }
    .bp-hero-img { max-height: 380px; }
    .bp-hero-fade { height: 80px; }

    .bp-header { padding: 40px 20px 28px; }
    .bp-back { margin-bottom: 28px; }
    .bp-eyebrow { letter-spacing: 2.5px; }
    .bp-title { font-size: 44px; line-height: 1; }
    .bp-excerpt { font-size: 17px; margin-bottom: 28px; }
    .bp-meta-row { gap: 12px; margin-bottom: 24px; }

    .bp-content { padding: 16px 20px 60px; }
    .bp-content-inner :global(.bp-p) { font-size: 18px; margin-bottom: 26px; }
    .bp-content-inner > :global(.bp-p:first-child::first-letter) {
      font-size: 3.6em; margin: 8px 10px 0 0;
    }
    .bp-content-inner :global(.bp-h2) { font-size: 30px; margin: 48px 0 16px; }
    .bp-content-inner :global(.bp-h3) { font-size: 13px; letter-spacing: 2px; margin: 36px 0 12px; }
    .bp-content-inner :global(.bp-quote) { font-size: 21px; padding: 32px 10px; margin: 36px 0; }
    .bp-content-inner :global(.bp-scripture) { font-size: 16px; padding: 20px 20px 20px 24px; margin-top: 40px; }
    .bp-content-inner :global(.bp-scripture + .bp-p) { font-size: 18px; padding: 0 24px 24px; }
    .bp-content-inner :global(.bp-ul),
    .bp-content-inner :global(.bp-ol) { font-size: 18px; margin-bottom: 26px; }
    .bp-content-inner :global(.bp-ul .bp-li::before) { top: 12px; }
  }
</style>
